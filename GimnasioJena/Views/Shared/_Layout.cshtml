<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Gimnasio Jena</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts: Audiowide para títulos y Montserrat para cuerpo -->
    <link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --gym-dark-bg: #293039;
            --gym-header-bg: #0F0F0F;
            --gym-accent: #FF6600;
            --gym-text: #FFFFFF;
            --gym-light-bg: #FFFFFF;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--gym-dark-bg);
            color: var(--gym-text);
            line-height: 1.6;
        }

        h1, h2, h3, h4, h5, h6, .display-1, .display-2, .display-3, .display-4, .display-5 {
            font-family: 'Audiowide', sans-serif;
            font-weight: 400;
            letter-spacing: 2px;
        }

        /* Navbar Apex Gym */
        .navbar-apex {
            background-color: var(--gym-header-bg);
            border-bottom: 2px solid var(--gym-accent);
            padding: 1rem 0;
        }

        .navbar-apex .navbar-brand {
            color: var(--gym-accent) !important;
            font-family: 'Audiowide', sans-serif;
            font-size: 1.8rem;
            font-weight: 400;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .navbar-apex .nav-link {
            color: var(--gym-text) !important;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 0.5rem 1rem !important;
            transition: color 0.3s ease;
        }

        .navbar-apex .nav-link:hover,
        .navbar-apex .nav-link.active {
            color: var(--gym-accent) !important;
        }

        .navbar-toggler {
            border-color: var(--gym-accent);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%23FF6600' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        /* Botón Unirse Ahora */
        .btn-join-now {
            background-color: var(--gym-accent);
            color: var(--gym-text);
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            border: none;
            padding: 0.75rem 2rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(255, 102, 0, 0.3);
        }

        .btn-join-now:hover {
            background-color: #cc5200;
            color: var(--gym-text);
            box-shadow: 0 6px 20px rgba(255, 102, 0, 0.5);
            transform: translateY(-2px);
        }

        /* Botones generales */
        .btn-apex-primary {
            background-color: var(--gym-accent);
            color: var(--gym-text);
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            border: none;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(255, 102, 0, 0.3);
        }

        .btn-apex-primary:hover {
            background-color: #cc5200;
            color: var(--gym-text);
            box-shadow: 0 6px 20px rgba(255, 102, 0, 0.5);
            transform: translateY(-2px);
        }

        /* Footer */
        footer {
            background-color: var(--gym-header-bg);
            color: var(--gym-text);
            padding: 3rem 0 1.5rem;
            border-top: 2px solid var(--gym-accent);
        }

        footer .footer-logo {
            color: var(--gym-accent);
            font-family: 'Audiowide', sans-serif;
            font-size: 1.5rem;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        footer h5 {
            color: var(--gym-accent);
            font-family: 'Audiowide', sans-serif;
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            letter-spacing: 1px;
        }

        footer a {
            color: var(--gym-text);
            text-decoration: none;
            transition: color 0.3s ease;
            font-size: 0.95rem;
        }

        footer a:hover {
            color: var(--gym-accent);
        }

        footer .social-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background-color: var(--gym-accent);
            color: var(--gym-text);
            border-radius: 50%;
            margin-right: 0.5rem;
            transition: all 0.3s ease;
            font-size: 1.2rem;
        }

        footer .social-icon:hover {
            background-color: var(--gym-text);
            color: var(--gym-accent);
            transform: translateY(-3px);
        }

        footer .copyright {
            border-top: 1px solid #333;
            padding-top: 1.5rem;
            margin-top: 2rem;
            font-size: 0.85rem;
            color: #999;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .navbar-apex .navbar-brand {
                font-size: 1.4rem;
            }

            .btn-join-now {
                padding: 0.6rem 1.5rem;
                font-size: 0.85rem;
            }

            footer {
                text-align: center;
            }

            footer .social-icon {
                margin: 0 0.25rem;
            }
        }
    </style>
</head>
<body>
    <!-- Navbar Apex -->
    <nav class="navbar navbar-expand-lg navbar-apex sticky-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                GIMNASIO JÉNA
            </a>
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarApex"
                    aria-controls="navbarApex" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarApex">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        @Html.ActionLink("Inicio", "Index", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Clases", "About", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Entrenador", "Operaciones", "Operacion", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Cliente", "MiPerfil", "Clientes", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Administrador", "Index", "Admin", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Precios", "Planes", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Contacto", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item ms-lg-2">
                        <a href="@Url.Action("Register", "Account")" class="btn btn-join-now">Unirse Ahora</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    @RenderBody()

    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-4">
                    <div class="footer-logo mb-3">GIMNASIO JENA</div>
                    <p class="mb-3" style="color: #ccc;">
                        Transforma tu cuerpo y tu mente. Únete a nosotros y alcanza tus metas fitness con el mejor equipo y entrenadores.
                    </p>
                    <div class="social-links">
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h5>Enlaces Rápidos</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">@Html.ActionLink("Inicio", "Index", "Home")</li>
                        <li class="mb-2">@Html.ActionLink("Sobre Nosotros", "About", "Home")</li>
                        <li class="mb-2">@Html.ActionLink("Clases", "About", "Home")</li>
                        <li class="mb-2">@Html.ActionLink("Contacto", "Contact", "Home")</li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h5>Servicios</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#">Entrenamiento Personal</a></li>
                        <li class="mb-2"><a href="#">Clases Grupales</a></li>
                        <li class="mb-2"><a href="#">Planes Nutricionales</a></li>
                        <li class="mb-2"><a href="#">Membresías</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h5>Contacto</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="bi bi-geo-alt-fill me-2" style="color: var(--gym-accent);"></i>Calle Principal 123</li>
                        <li class="mb-2"><i class="bi bi-telephone-fill me-2" style="color: var(--gym-accent);"></i>+57 300 123 4567</li>
                        <li class="mb-2"><i class="bi bi-envelope-fill me-2" style="color: var(--gym-accent);"></i>info@gimnasiojena.com</li>
                        <li class="mb-2"><i class="bi bi-clock-fill me-2" style="color: var(--gym-accent);"></i>Lun-Sáb: 5AM - 10PM</li>
                    </ul>
                </div>
            </div>
            <div class="copyright text-center">
                <p class="mb-0">&copy; @DateTime.Now.Year Gimnasio Jena. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>