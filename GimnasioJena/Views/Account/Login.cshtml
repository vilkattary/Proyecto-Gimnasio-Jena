@{
    ViewBag.Title = "Login";
}
<style>
    :root {
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;
        --jena-card-bg: #293039;
        --jena-orange: #FF6B35;
        --jena-light-blue: #8DA9C4;
        --jena-white: #FFFFFF;
        --jena-dark-orange: #D95F31;
        --jena-light-gray: #F8F9FA;
    }

    .btn-action {
        background-color: var(--jena-white);
        color: var(--jena-navy);
        border: 2px solid var(--jena-dark-orange);
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(217, 95, 49, 0.15);
        width: 100%;
        margin-bottom: 15px;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-action:last-child {
            margin-bottom: 0;
        }

        .btn-action:hover {
            background-color: var(--jena-dark-orange);
            color: var(--jena-white);
            border-color: var(--jena-dark-orange);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(217, 95, 49, 0.4);
        }

        .btn-action:active {
            transform: translateY(-1px);
        }

        .btn-action i {
            font-size: 1.2rem;
            color: var(--jena-dark-orange);
            transition: color 0.3s ease;
        }

        .btn-action:hover i {
            color: var(--jena-white);
        }
</style>
<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-sm-10 col-md-8 col-lg-5">
            <div class="card shadow-sm rounded-4" style="border-top:4px solid var(--gym-orange);">
                <div class="card-body p-4">
                    <div class="text-center mb-3">
                        <span class="d-inline-block fs-3 fst-italic" style="color:var(--gym-orange); font-family:'Oswald',sans-serif;">
                            <i class="bi bi-lightning-charge-fill me-1"></i>GIMNASIO JENA
                        </span>
                        <h2 class="h5 mt-2 fw-bold" style="color:var(--gym-dark);">Accede a tu cuenta</h2>
                    </div>

                    @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        <div class="mb-3">
                            <label for="Email" class="form-label fw-600">Correo electrónico</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0" style="color:var(--gym-orange);">
                                    <i class="bi bi-person-fill"></i>
                                </span>
                                <input type="email" name="Email" id="Email" class="form-control border-start-0" placeholder="tu@correo.com" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="Password" class="form-label fw-600">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0" style="color:var(--gym-orange);">
                                    <i class="bi bi-lock-fill"></i>
                                </span>
                                <input type="password" name="Password" id="Password" class="form-control border-start-0" placeholder="********" required />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="true" name="RememberMe" id="RememberMe" />
                                <label class="form-check-label small" for="RememberMe">Recuérdame</label>
                            </div>
                            <a href="@Url.Action("ForgotPassword", "Account")" class="small" style="color:var(--gym-orange); text-decoration:none;">¿Olvidaste la contraseña?</a>
                        </div>

                        <button type="submit" class="btn btn-action w-100 py-2">Entrar</button>

                        <div class="text-center mt-3">
                            <span class="small text-muted">¿No tienes cuenta?</span>
                            <a href="@Url.Action("Register", "Account")" class="btn btn-outline-gym btn-sm ms-2">Regístrate</a>
                        </div>
                    }
                </div>
            </div>

            <p class="text-center text-muted small mt-3">Al iniciar sesión aceptas las condiciones del gimnasio.</p>
        </div>
    </div>
</section>

