@{
    ViewBag.Title = "Nosotros";
}

<!-- Page Header -->
<section style="background: linear-gradient(135deg, #111111 60%, #2c2c2c 100%); padding: 80px 0 60px;">
    <div class="container text-center">
        <p class="text-uppercase mb-2" style="color:#FF6600; font-family:'Oswald',sans-serif; letter-spacing:3px; font-size:1rem;">
            <i class="bi bi-info-circle-fill me-1"></i> Quiénes somos
        </p>
        <h1 class="display-4 fw-bold text-white mb-3">SOBRE <span style="color:#FF6600;">NOSOTROS</span></h1>
        <div class="mx-auto" style="width:60px; height:4px; background:#FF6600; border-radius:2px;"></div>
    </div>
</section>

<!-- Mission & Vision -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <p class="text-uppercase mb-1" style="color:#FF6600; font-family:'Oswald',sans-serif; letter-spacing:3px;">Nuestra historia</p>
                <h2 class="fw-bold display-6 mb-3" style="color:#111;">MÁS DE 10 AÑOS FORJANDO CAMPEONES</h2>
                <p class="text-muted mb-3">
                    Gimnasio Jena nació con una misión clara: ofrecer a nuestra comunidad un espacio de entrenamiento de alto rendimiento,
                    accesible para todos. Desde nuestros inicios hemos crecido junto a cientos de miembros que han alcanzado sus metas
                    de salud y bienestar.
                </p>
                <p class="text-muted mb-4">
                    Contamos con instalaciones modernas, equipos de última generación y un equipo de entrenadores certificados
                    comprometidos con tu progreso personal.
                </p>
                <div class="row g-3">
                    <div class="col-4 text-center">
                        <div class="fw-bold display-6" style="color:#FF6600; font-family:'Oswald',sans-serif;">500+</div>
                        <div class="text-muted small">Miembros activos</div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="fw-bold display-6" style="color:#FF6600; font-family:'Oswald',sans-serif;">10+</div>
                        <div class="text-muted small">Años de experiencia</div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="fw-bold display-6" style="color:#FF6600; font-family:'Oswald',sans-serif;">20+</div>
                        <div class="text-muted small">Clases semanales</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <i class="bi bi-lightning-charge-fill" style="font-size:14rem; color:#FF6600; opacity:0.1;"></i>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision Cards -->
<section class="py-5" style="background:#f5f5f5;">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4" style="border-left:5px solid #FF6600 !important;">
                    <i class="bi bi-bullseye mb-3" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h4 class="fw-bold mb-3" style="font-family:'Oswald',sans-serif; color:#111;">NUESTRA MISIÓN</h4>
                    <p class="text-muted mb-0">
                        Proporcionar un ambiente motivador y seguro donde cada persona pueda alcanzar sus objetivos de salud
                        y condición física, con el apoyo de profesionales especializados y equipos de primer nivel.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4" style="border-left:5px solid #FF6600 !important;">
                    <i class="bi bi-eye-fill mb-3" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h4 class="fw-bold mb-3" style="font-family:'Oswald',sans-serif; color:#111;">NUESTRA VISIÓN</h4>
                    <p class="text-muted mb-0">
                        Ser el gimnasio de referencia en la región, reconocido por la calidad de nuestros servicios,
                        la excelencia de nuestros entrenadores y el impacto positivo en la salud de nuestra comunidad.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values -->
<section class="py-5" style="background:#1a1a1a;">
    <div class="container">
        <div class="text-center mb-5">
            <p class="text-uppercase mb-1" style="color:#FF6600; font-family:'Oswald',sans-serif; letter-spacing:3px;">Lo que nos define</p>
            <h2 class="fw-bold display-5 text-white">NUESTROS VALORES</h2>
            <div class="mx-auto mt-2" style="width:60px; height:4px; background:#FF6600; border-radius:2px;"></div>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3 text-center">
                <div class="p-3">
                    <i class="bi bi-award-fill mb-3 d-block" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h5 class="fw-bold text-white" style="font-family:'Oswald',sans-serif;">Excelencia</h5>
                    <p class="text-secondary small">Buscamos la mejora continua en cada servicio que ofrecemos a nuestros miembros.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 text-center">
                <div class="p-3">
                    <i class="bi bi-heart-fill mb-3 d-block" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h5 class="fw-bold text-white" style="font-family:'Oswald',sans-serif;">Compromiso</h5>
                    <p class="text-secondary small">Estamos dedicados al bienestar y progreso de cada uno de nuestros miembros.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 text-center">
                <div class="p-3">
                    <i class="bi bi-people-fill mb-3 d-block" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h5 class="fw-bold text-white" style="font-family:'Oswald',sans-serif;">Comunidad</h5>
                    <p class="text-secondary small">Fomentamos un ambiente inclusivo donde todos se sienten bienvenidos y motivados.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 text-center">
                <div class="p-3">
                    <i class="bi bi-shield-fill-check mb-3 d-block" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h5 class="fw-bold text-white" style="font-family:'Oswald',sans-serif;">Integridad</h5>
                    <p class="text-secondary small">Actuamos con honestidad y transparencia en todo lo que hacemos.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5" style="background:#FF6600;">
    <div class="container text-center">
        <h2 class="fw-bold display-5 text-white mb-3" style="font-family:'Oswald',sans-serif;">
            ¿QUIERES SER PARTE DE NUESTRA FAMILIA?
        </h2>
        <p class="text-white mb-4" style="opacity:0.9; max-width:500px; margin:auto;">
            Únete a los cientos de miembros que ya confían en Gimnasio Jena para alcanzar sus objetivos.
        </p>
        <a href="@Url.Action("Contact", "Home")" class="btn btn-dark btn-lg px-5" style="font-family:'Oswald',sans-serif; letter-spacing:1px;">
            <i class="bi bi-person-plus-fill me-2"></i>ÚNETE AHORA
        </a>
    </div>
</section>