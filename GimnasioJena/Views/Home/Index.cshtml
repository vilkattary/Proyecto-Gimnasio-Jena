@{
    ViewBag.Title = "Inicio";
}

<!-- Hero Section -->
<section style="background: linear-gradient(135deg, #111111 60%, #2c2c2c 100%); min-height: 90vh;" class="d-flex align-items-center">
    <div class="container py-5">
        <div class="row align-items-center gy-5">
            <div class="col-lg-7">
                <p class="text-uppercase mb-2" style="color:#FF6600; font-family:'Oswald',sans-serif; letter-spacing:3px; font-size:1rem;">
                    <i class="bi bi-lightning-charge-fill me-1"></i> Bienvenido a
                </p>
                <h1 class="display-3 fw-bold text-white mb-3">GIMNASIO<br><span style="color:#FF6600;">JENA</span></h1>
                <p class="lead text-light mb-4" style="max-width:520px;">
                    Tu mejor versión te está esperando. Entrenamiento de alto rendimiento,
                    equipos modernos y un equipo de profesionales dedicado a tus metas.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="@Url.Action("Contact", "Home")" class="btn btn-gym btn-lg px-4">
                        <i class="bi bi-person-plus-fill me-2"></i>Únete ahora
                    </a>
                    <a href="@Url.Action("Login", "Login")" class="btn btn-gym btn-lg px-4">
                        <i class="bi bi-person-plus-fill me-2"></i>Únete ahora
                    </a>

                    <a href="@Url.Action("Planes", "Home")" class="btn btn-outline-gym btn-lg px-4">
                        Conoce nuestros planes
                    </a>
                </div>

                <!-- Stats Row -->
                <div class="row mt-5 gy-3">
                    <div class="col-4 text-center">
                        <div class="fw-bold display-6" style="color:#FF6600; font-family:'Oswald',sans-serif;">500+</div>
                        <div class="text-light small">Miembros activos</div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="fw-bold display-6" style="color:#FF6600; font-family:'Oswald',sans-serif;">10+</div>
                        <div class="text-light small">Años de experiencia</div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="fw-bold display-6" style="color:#FF6600; font-family:'Oswald',sans-serif;">20+</div>
                        <div class="text-light small">Clases semanales</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 text-center d-none d-lg-block">
                <i class="bi bi-lightning-charge-fill" style="font-size:16rem; color:#FF6600; opacity:0.15;"></i>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <p class="text-uppercase mb-1" style="color:#FF6600; font-family:'Oswald',sans-serif; letter-spacing:3px;">Lo que ofrecemos</p>
            <h2 class="fw-bold display-5" style="color:#111;">NUESTROS SERVICIOS</h2>
            <div class="mx-auto mt-2" style="width:60px; height:4px; background:#FF6600; border-radius:2px;"></div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4" style="border-top:4px solid #FF6600 !important;">
                    <i class="bi bi-heart-pulse-fill mb-3" style="font-size:3rem; color:#FF6600;"></i>
                    <h4 class="fw-bold" style="font-family:'Oswald',sans-serif; color:#111;">Cardio & Resistencia</h4>
                    <p class="text-muted">Cinta, bicicleta estática, elípticas y equipos de cardio de última generación para quemar calorías.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4" style="border-top:4px solid #FF6600 !important;">
                    <i class="bi bi-trophy-fill mb-3" style="font-size:3rem; color:#FF6600;"></i>
                    <h4 class="fw-bold" style="font-family:'Oswald',sans-serif; color:#111;">Sala de Pesas</h4>
                    <p class="text-muted">Zona de musculación completa con mancuernas, barras olímpicas, máquinas guiadas y zona functional.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4" style="border-top:4px solid #FF6600 !important;">
                    <i class="bi bi-people-fill mb-3" style="font-size:3rem; color:#FF6600;"></i>
                    <h4 class="fw-bold" style="font-family:'Oswald',sans-serif; color:#111;">Clases Grupales</h4>
                    <p class="text-muted">Zumba, spinning, yoga, crossfit y más. Instructores certificados que te motivarán cada sesión.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Us Section -->
<section class="py-5" style="background:#1a1a1a;">
    <div class="container">
        <div class="text-center mb-5">
            <p class="text-uppercase mb-1" style="color:#FF6600; font-family:'Oswald',sans-serif; letter-spacing:3px;">¿Por qué elegirnos?</p>
            <h2 class="fw-bold display-5 text-white">TU ÉXITO ES NUESTRA MISIÓN</h2>
            <div class="mx-auto mt-2" style="width:60px; height:4px; background:#FF6600; border-radius:2px;"></div>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3 text-center">
                <div class="p-3">
                    <i class="bi bi-clock-fill mb-3 d-block" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h5 class="fw-bold text-white" style="font-family:'Oswald',sans-serif;">Horario Amplio</h5>
                    <p class="text-secondary small">Abierto de lunes a sábado de 5:00 AM a 10:00 PM para que entrenes a tu ritmo.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 text-center">
                <div class="p-3">
                    <i class="bi bi-person-check-fill mb-3 d-block" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h5 class="fw-bold text-white" style="font-family:'Oswald',sans-serif;">Entrenadores Expertos</h5>
                    <p class="text-secondary small">Profesionales certificados que diseñan planes personalizados según tus objetivos.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 text-center">
                <div class="p-3">
                    <i class="bi bi-shield-check-fill mb-3 d-block" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h5 class="fw-bold text-white" style="font-family:'Oswald',sans-serif;">Ambiente Seguro</h5>
                    <p class="text-secondary small">Instalaciones limpias, seguras y con todo el equipamiento bien mantenido.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 text-center">
                <div class="p-3">
                    <i class="bi bi-graph-up-arrow mb-3 d-block" style="font-size:2.5rem; color:#FF6600;"></i>
                    <h5 class="fw-bold text-white" style="font-family:'Oswald',sans-serif;">Resultados Reales</h5>
                    <p class="text-secondary small">Seguimiento continuo de tu progreso para que alcances tus metas más rápido.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5" style="background:#FF6600;">
    <div class="container text-center">
        <h2 class="fw-bold display-5 text-white mb-3" style="font-family:'Oswald',sans-serif;">
            ¿LISTO PARA EMPEZAR?
        </h2>
        <p class="text-white mb-4" style="opacity:0.9; max-width:500px; margin:auto;">
            Contáctanos hoy y recibe tu primera semana de prueba <strong>completamente gratis</strong>.
        </p>
        <a href="@Url.Action("Contact", "Home")" class="btn btn-dark btn-lg px-5" style="font-family:'Oswald',sans-serif; letter-spacing:1px;">
            <i class="bi bi-envelope-fill me-2"></i>CONTÁCTANOS
        </a>
    </div>
</section>