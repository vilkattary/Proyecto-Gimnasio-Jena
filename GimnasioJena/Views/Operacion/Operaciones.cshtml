@{
    ViewBag.Title = "Dashboard del Entrenador";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<style>
    :root {
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;
        --jena-card-bg: #293039;
        --jena-orange: #FF6B35;
        --jena-light-blue: #8DA9C4;
        --jena-white: #FFFFFF;
        --jena-dark-orange: #D95F31;
        --jena-light-gray: #F8F9FA;
    }

    body {
        font-family: 'Montserrat', sans-serif;
        background-color: var(--jena-white);
        color: var(--jena-navy);
    }

    .dashboard-section {
        background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
        min-height: 85vh;
        padding: 3rem 0;
    }

    .dashboard-title {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 800;
        letter-spacing: 3px;
        color: var(--jena-navy);
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .divider-jena {
        width: 120px;
        height: 5px;
        background: var(--jena-orange);
        border-radius: 3px;
        margin: 0 auto 3rem;
    }
    /* ============================================
BOTONES DE ACCIÓN
============================================ */
    .action-buttons-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        margin-bottom: 30px;
    }

        .action-buttons-card h5 {
            color: var(--jena-navy);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            text-align: center;
            position: relative;
            padding-bottom: 12px;
        }

            .action-buttons-card h5::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 3px;
                background-color: var(--jena-orange);
            }

    .btn-action {
        background-color: var(--jena-white);
        color: var(--jena-navy); 
        border: 2px solid var(--jena-orange);
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.15);
        width: 100%;
        margin-bottom: 15px;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-action:last-child {
            margin-bottom: 0;
        }

        .btn-action:hover {
            background-color: var(--jena-orange);
            color: var(--jena-white); 
            border-color: var(--jena-orange);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

        .btn-action:active {
            transform: translateY(-1px);
        }

        .btn-action i {
            font-size: 1.2rem;
            color: var(--jena-orange);
            transition: color 0.3s ease;
        }

        .btn-action:hover i {
            color: var(--jena-white);
        }

    /* Sección de Saludo con Logo Jéna */
    .welcome-section {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 2rem;
        margin-bottom: 3rem;
        flex-wrap: wrap;
    }

    .logo-jena {
        width: 140px;
        height: 140px;
        background-color: var(--jena-orange);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 4px solid var(--jena-light-blue);
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.3);
        position: relative;
        overflow: hidden;
    }

    .logo-jena svg {
        width: 100%;
        height: 100%;
    }

    /* Árbol con raíces y J superpuesta - simulación del logo */
    .logo-jena-content {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .logo-jena-j {
        font-size: 5rem;
        font-weight: 800;
        color: var(--jena-dark-navy);
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 2;
    }

    .logo-jena-tree {
        position: absolute;
        font-size: 3rem;
        color: var(--jena-dark-orange);
        z-index: 1;
        opacity: 0.7;
    }

    .welcome-text {
        text-align: left;
    }

    .welcome-text h4 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--jena-navy);
    }

    .welcome-text .highlight {
        color: var(--jena-orange);
        font-weight: 800;
    }

    /* Tarjetas CTA con fondo #293039 */
    .card-jena {
        background: #293039;
        border: 2px solid var(--jena-orange);
        border-radius: 20px;
        padding: 2.5rem 2rem;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        height: 100%;
        position: relative;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(41, 48, 57, 0.3);
    }

    .card-jena::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: var(--jena-orange);
        transform: scaleX(0);
        transition: transform 0.4s ease;
    }

    .card-jena:hover::before {
        transform: scaleX(1);
    }

    .card-jena:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(255, 107, 53, 0.4);
        border-color: var(--jena-orange);
        background: #1F262D;
    }

    .card-jena h5 {
        color: var(--jena-orange);
        font-weight: 700;
        font-size: 1.4rem;
        margin-bottom: 1.5rem;
        letter-spacing: 1px;
    }

    .card-jena .icon-wrapper {
        margin-bottom: 1.5rem;
    }

    .card-jena i {
        font-size: 3rem;
        color: var(--jena-orange);
        transition: transform 0.3s ease;
    }

    .card-jena:hover i {
        transform: scale(1.15);
    }

    .card-jena p {
        color: var(--jena-light-blue);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

    .btn-jena {
        background-color: var(--jena-orange);
        color: var(--jena-white);
        border: 2px solid var(--jena-orange);
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
        padding: 0.75rem 2rem;
        border-radius: 50px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-jena:hover {
        background-color: transparent;
        color: var(--jena-orange);
        border-color: var(--jena-orange);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 107, 53, 0.4);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .dashboard-title {
            font-size: 2rem;
            letter-spacing: 1px;
        }

        .welcome-section {
            flex-direction: column;
            text-align: center;
        }

        .welcome-text {
            text-align: center;
        }

        .logo-jena {
            width: 120px;
            height: 120px;
        }

        .logo-jena-j {
            font-size: 4rem;
        }

        .card-jena {
            margin-bottom: 1.5rem;
        }
    }
</style>

<section class="dashboard-section">
    <div class="container">
        <div class="text-center">
            <h1 class="dashboard-title">DASHBOARD DEL ENTRENADOR</h1>
            <div class="divider-jena"></div>
        </div>

        <!-- Sección de Saludo Personalizado con Logo Jéna -->
        <div class="welcome-section">
            <div class="logo-jena">
                <div class="logo-jena-content">
                    <!-- Simulación del árbol (puedes reemplazar con imagen real) -->
                    <i class="bi bi-tree logo-jena-tree"></i>
                    <!-- La J característica del logo superpuesta -->
                    <span class="logo-jena-j">J</span>
                </div>
            </div>
            <div class="welcome-text">
                <h4>Sandra Hernández, <span class="highlight">¿qué deseas gestionar?</span></h4>
            </div>
        </div>

        <!-- Tarjetas CTA -->
        <div class="row g-4 justify-content-center">
            <!-- Tarjeta 1: Lista de Asistencia -->
            <div class="col-lg-4 col-md-6">
                <div class="card-jena">
                    <h5>Lista de Asistencia</h5>
                    <div class="icon-wrapper">
                        <i class="bi bi-clipboard-check"></i>
                    </div>
                    <p>Busca la clase y marca quién asistió.</p>
                    <a href="@Url.Action("ListaAsistencia", "Operacion")" class="btn-action">Ver detalles</a>
                </div>
            </div>

            <!-- Tarjeta 2: Panel de Mensajes -->
            <div class="col-lg-4 col-md-6">
                <div class="card-jena">
                    <h5>Panel de Mensajes</h5>
                    <div class="icon-wrapper">
                        <i class="bi bi-chat-dots"></i>
                    </div>
                    <p>Tienes 8 mensajes nuevos por revisar.</p>
                    <a href="@Url.Action("PanelMensajes", "Operacion")" class="btn-action">Abrir bandeja</a>
                </div>
            </div>

            <!-- Tarjeta 3: Mis Clases -->
            <div class="col-lg-4 col-md-6">
                <div class="card-jena">
                    <h5>Mis Clases</h5>
                    <div class="icon-wrapper">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <p>Tienes 4 clases próximas agendadas.</p>
                    <a href="@Url.Action("MisClases", "Operacion")" class="btn-action">Ver calendario</a>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>