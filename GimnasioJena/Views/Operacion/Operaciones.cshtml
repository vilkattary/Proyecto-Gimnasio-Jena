@{
    ViewBag.Title = "Operaciones";
}

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        font-family: 'Oswald', sans-serif;
        background-color: #111;
        color: #fff;
    }

    .section-overlay {
        background: rgba(0, 0, 0, 0.75);
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .card-operacion {
        background-color: #000;
        border: 2px solid #FF6600;
        transition: all 0.3s ease;
    }

        .card-operacion:hover {
            transform: translateY(-5px);
            box-shadow: 0 0 15px #FF6600;
        }

    .btn-orange {
        background-color: #FF6600;
        color: #fff;
        border: none;
        transition: 0.3s;
    }

        .btn-orange:hover {
            background-color: #e65c00;
            transform: scale(1.05);
        }

    .divider {
        width: 100px;
        height: 4px;
        background: #FF6600;
        border-radius: 2px;
        margin: 0 auto;
    }
</style>

<section style="background:url('/images/gym-background.jpg') center/cover no-repeat; position:relative; min-height:80vh;" class="py-5">
    <div class="section-overlay"></div>
    <div class="container position-relative text-center">
        <h1 class="fw-bold mb-2" style="font-size:3rem; letter-spacing:2px;">OPERACIONES</h1>
        <div class="divider mb-4"></div>

        <div class="d-flex justify-content-center align-items-center mb-5">
            <img src="https://share.google/snfokBnq8hElY1WJ0" alt="Foto de perfil"
                 class="rounded-circle border shadow me-3"
                 style="border:3px solid #FF6600; width:120px; height:120px; object-fit:cover;">
            <h4 class="mb-0">Sandra Hernández, <span style="color:#FF6600;">¿qué deseas gestionar?</span></h4>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-3 mx-2 mb-4">
                <div class="card-operacion p-4 rounded text-center">
                    <h5 class="fw-bold mb-3" style="color:#FF6600;">Lista de Asistencia</h5>
                    <i class="bi bi-clipboard-check" style="font-size:2.5rem; color:#FF6600;"></i>
                    <p class="mt-3">Busca la clase y marca quién asistió.</p>
                    <a href="@Url.Action("ListaAsistencia", "Operacion")" class="btn btn-orange fw-semibold mt-2">Ver detalles</a>
                </div>
            </div>

            <div class="col-md-3 mx-2 mb-4">
                <div class="card-operacion p-4 rounded text-center">
                    <h5 class="fw-bold mb-3" style="color:#FF6600;">Panel de Mensajes</h5>
                    <i class="bi bi-chat-dots" style="font-size:2.5rem; color:#FF6600;"></i>
                    <p class="mt-3">Tienes 8 mensajes nuevos por revisar.</p>
                    <a href="@Url.Action("PanelMensajes", "Operacion")" class="btn btn-orange fw-semibold mt-2">Abrir bandeja</a>
                </div>
            </div>

            <div class="col-md-3 mx-2 mb-4">
                <div class="card-operacion p-4 rounded text-center">
                    <h5 class="fw-bold mb-3" style="color:#FF6600;">Mis Clases</h5>
                    <i class="bi bi-calendar-check" style="font-size:2.5rem; color:#FF6600;"></i>
                    <p class="mt-3">Tienes 4 clases próximas agendadas.</p>
                    <a href="@Url.Action("MisClases", "Operacion")" class="btn btn-orange fw-semibold mt-2">Ver calendario</a>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.js"></script>
