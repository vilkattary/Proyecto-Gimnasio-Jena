@{
    ViewBag.Title = "ListaAsistencia";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<style>
    /* ============================================
       SISTEMA DE DISEÑO - GIMNASIO JENA
       ============================================ */
    :root {
        /* Colores Core */
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;
        /* Colores de Acento */
        --jena-orange: #FF6B35;
        --jena-dark-orange: #D95F31;
        /* Colores de Soporte */
        --jena-light-blue: #6C8EA4;
        --jena-white: #FFFFFF;
        --jena-light-gray: #F8F9FA;
        /* Tipografía */
        --font-primary: 'Montserrat', sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background: linear-gradient(180deg, var(--jena-white) 0%, var(--jena-light-gray) 100%);
        color: var(--jena-navy);
        min-height: 100vh;
    }

    /* ============================================
       SIDEBAR
       ============================================ */
    .sidebar {
        background-color: var(--jena-dark-navy);
        color: var(--jena-white);
        min-height: 100vh;
        padding: 30px 20px;
        box-shadow: 4px 0 15px rgba(0, 0, 0, 0.1);
    }

        .sidebar h4 {
            color: var(--jena-orange);
            margin-bottom: 30px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 3px;
            font-size: 1.1rem;
            position: relative;
            padding-bottom: 15px;
        }

            .sidebar h4::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                width: 60px;
                height: 3px;
                background-color: var(--jena-orange);
            }

        .sidebar ul {
            list-style: none;
            padding: 0;
        }

            .sidebar ul li {
                margin-bottom: 12px;
                padding: 12px 16px;
                border-radius: 50px;
                cursor: pointer;
                transition: all 0.3s ease;
                font-weight: 600;
                font-size: 0.95rem;
                border: 2px solid transparent;
            }

                .sidebar ul li:hover {
                    background-color: var(--jena-orange);
                    color: var(--jena-white);
                    transform: translateX(8px);
                    border-color: var(--jena-orange);
                }

                .sidebar ul li.active {
                    background-color: var(--jena-orange);
                    color: var(--jena-white);
                    border-color: var(--jena-dark-orange);
                    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
                }

    /* ============================================
       CONTENT AREA
       ============================================ */
    .content {
        padding: 40px;
    }

    .page-title {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 8px;
        position: relative;
        display: inline-block;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 5px;
            background-color: var(--jena-orange);
        }

    .page-subtitle {
        color: var(--jena-navy);
        font-weight: 400;
        margin-bottom: 30px;
    }

        .page-subtitle .highlight {
            color: var(--jena-orange);
            font-weight: 600;
        }

    /* ============================================
       CARDS DE GESTIÓN
       ============================================ */
    .filter-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .filter-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 0;
            background-color: var(--jena-orange);
            transition: height 0.3s ease;
        }

        .filter-card:hover {
            border-color: var(--jena-orange);
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.2);
        }

            .filter-card:hover::before {
                height: 5px;
            }

    .form-label {
        color: var(--jena-navy);
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .form-select,
    .form-control {
        border: 2px solid var(--jena-light-blue);
        border-radius: 12px;
        padding: 10px 15px;
        font-weight: 400;
        transition: all 0.3s ease;
    }

        .form-select:focus,
        .form-control:focus {
            border-color: var(--jena-orange);
            box-shadow: 0 0 0 0.25rem rgba(255, 107, 53, 0.15);
        }

    /* ============================================
       BOTONES (ESTILO PÍLDORA)
       ============================================ */
    .btn-orange {
        background-color: var(--jena-orange);
        color: var(--jena-white);
        border: none;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
    }

        .btn-orange:hover {
            background-color: var(--jena-dark-orange);
            color: var(--jena-white);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

        .btn-orange:active {
            transform: translateY(-1px);
        }

    /* ============================================
       TABLA DE ASISTENCIA
       ============================================ */
    .attendance-table-wrapper {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

        .table thead {
            background-color: var(--jena-orange);
            color: var(--jena-white);
        }

            .table thead th {
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                padding: 15px;
                border: none;
                font-size: 0.9rem;
            }

        .table tbody tr {
            transition: all 0.3s ease;
            border-bottom: 1px solid var(--jena-light-gray);
        }

            .table tbody tr:hover {
                background-color: rgba(255, 107, 53, 0.05);
                transform: scale(1.01);
            }

            .table tbody tr td {
                padding: 15px;
                vertical-align: middle;
                color: var(--jena-navy);
                font-weight: 400;
            }

    .checkmark {
        color: #28a745;
        font-size: 1.5rem;
        font-weight: 800;
    }

    .crossmark {
        color: #dc3545;
        font-size: 1.5rem;
        font-weight: 800;
    }

    /* ============================================
       SECCIÓN DE LOGO CIRCULAR (BIENVENIDA)
       ============================================ */
    .welcome-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding: 20px;
        background-color: var(--jena-white);
        border-radius: 20px;
        border: 2px solid var(--jena-light-blue);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .logo-circular {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background-color: var(--jena-orange);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        flex-shrink: 0;
    }

        .logo-circular i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            position: absolute;
        }

        .logo-circular .letter-j {
            font-size: 5rem;
            color: var(--jena-dark-navy);
            font-weight: 800;
            font-family: var(--font-primary);
            position: relative;
            z-index: 1;
        }

    .welcome-text h3 {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .welcome-text p {
        color: var(--jena-light-blue);
        font-weight: 400;
        margin: 0;
    }

    /* ============================================
       ESTADÍSTICAS
       ============================================ */
    .stats-section {
        margin-top: 25px;
        padding: 20px;
        background-color: var(--jena-light-gray);
        border-radius: 15px;
        border: 2px solid var(--jena-light-blue);
    }

        .stats-section p {
            margin: 0;
            color: var(--jena-navy);
            font-weight: 600;
            font-size: 1rem;
        }

            .stats-section p strong {
                color: var(--jena-orange);
                font-weight: 800;
            }

    /* ============================================
       RESPONSIVE (MÓVILES < 768px)
       ============================================ */
    @@media (max-width: 768px) {
        .content {
            padding: 20px;
        }

        .page-title {
            font-size: 1.5rem;
            text-align: center;
            display: block;
        }

        .page-subtitle {
            text-align: center;
        }

        .logo-circular {
            width: 120px;
            height: 120px;
        }

            .logo-circular i {
                font-size: 3rem;
            }

            .logo-circular .letter-j {
                font-size: 4rem;
            }

        .welcome-section {
            flex-direction: column;
            text-align: center;
        }

        .filter-card {
            padding: 20px;
        }

            .filter-card .row > div {
                margin-bottom: 1.5rem;
            }

        .sidebar {
            min-height: auto;
            margin-bottom: 20px;
        }

        .table {
            font-size: 0.85rem;
        }

            .table thead th,
            .table tbody td {
                padding: 10px 8px;
            }
    }
</style>

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 sidebar">
            <h4><i class="bi bi-grid-fill me-2"></i>Cursos</h4>
            <ul>
                <li class="active"><i class="bi bi-bicycle me-2"></i>Clases de Spinning</li>
                <li><i class="bi bi-heart-pulse me-2"></i>Clases de Yoga</li>
                <li><i class="bi bi-trophy me-2"></i>Clases de Boxeo</li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="col-md-9 content">
            <!-- Sección de Bienvenida con Logo -->
            <div class="welcome-section">
                <div class="logo-circular">
                    <i class="bi bi-tree"></i>
                    <span class="letter-j">J</span>
                </div>
                <div class="welcome-text">
                    <h3>Bienvenida, Sandra Hernández</h3>
                    <p>Gestiona la asistencia de tus clases de forma eficiente</p>
                </div>
            </div>

            <!-- Título Principal -->
            <div class="text-center mb-4">
                <h2 class="page-title">Lista de Asistencia</h2>
            </div>
            <p class="page-subtitle text-center">Sandra Hernández, <span class="highlight">¿qué deseas gestionar?</span></p>

            <!-- Filtros (Card de Gestión) -->
            <div class="filter-card">
                <div class="row">
                    <div class="col-md-3 mb-3 mb-md-0">
                        <label class="form-label"><i class="bi bi-collection me-2"></i>Clase</label>
                        <select class="form-select">
                            <option>Spinning</option>
                            <option>Yoga</option>
                            <option>Boxeo</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3 mb-md-0">
                        <label class="form-label"><i class="bi bi-calendar-event me-2"></i>Fecha</label>
                        <input type="date" class="form-control" value="2026-05-30">
                    </div>
                    <div class="col-md-3 mb-3 mb-md-0">
                        <label class="form-label"><i class="bi bi-person-badge me-2"></i>Entrenador</label>
                        <select class="form-select">
                            <option>Diego Pérez</option>
                            <option>María Gómez</option>
                            <option>Carlos Ramírez</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-orange w-100"><i class="bi bi-search me-2"></i>Buscar</button>
                    </div>
                </div>
            </div>

            <!-- Tabla de Asistencia -->
            <div class="attendance-table-wrapper">
                <table class="table table-hover text-center align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Fecha</th>
                            <th>Asistencia</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td>Camila Soto</td>
                            <td>30/05/2026 10:00 AM</td>
                            <td><span class="checkmark">✔</span></td>
                        </tr>
                        <tr>
                            <td>2</td>
                            <td>Rubén Jiménez</td>
                            <td>30/05/2026 10:00 AM</td>
                            <td><span class="checkmark">✔</span></td>
                        </tr>
                        <tr>
                            <td>3</td>
                            <td>Carolina Arias</td>
                            <td>30/05/2026 10:00 AM</td>
                            <td><span class="crossmark">✘</span></td>
                        </tr>
                        <tr>
                            <td>4</td>
                            <td>Erick Pérez</td>
                            <td>30/05/2026 10:00 AM</td>
                            <td><span class="checkmark">✔</span></td>
                        </tr>
                        <tr>
                            <td>5</td>
                            <td>Lucía Vargas</td>
                            <td>30/05/2026 10:00 AM</td>
                            <td><span class="checkmark">✔</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Estadísticas -->
            <div class="stats-section">
                <p>
                    <strong>Total inscritos:</strong> 5
                    <span class="mx-3">|</span>
                    <strong>Presentes:</strong> 4
                    <span class="mx-3">|</span>
                    <strong>Ausentes:</strong> 1
                </p>
                <button class="btn btn-orange mt-3"><i class="bi bi-eye me-2"></i>Ver detalles</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>