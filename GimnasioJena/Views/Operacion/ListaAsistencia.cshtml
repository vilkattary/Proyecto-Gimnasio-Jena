@{
    ViewBag.Title = "ListaAsistencia";
}

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        font-family: 'Oswald', sans-serif;
        background-color: #fff;
        color: #000;
    }

    .sidebar {
        background-color: #111;
        color: #fff;
        min-height: 100vh;
        padding: 20px;
    }

        .sidebar h4 {
            color: #FF6600;
            margin-bottom: 20px;
            font-weight: 700;
        }

        .sidebar ul {
            list-style: none;
            padding: 0;
        }

            .sidebar ul li {
                margin-bottom: 15px;
                padding: 10px;
                border-radius: 5px;
                cursor: pointer;
                transition: 0.3s;
            }

                .sidebar ul li:hover,
                .sidebar ul li.active {
                    background-color: #FF6600;
                    color: #fff;
                }

    .content {
        padding: 40px;
    }

    .btn-orange {
        background-color: #FF6600;
        color: #fff;
        border: none;
        transition: 0.3s;
    }

        .btn-orange:hover {
            background-color: #e65c00;
            transform: scale(1.05);
        }

    .table thead {
        background-color: #FF6600;
        color: #fff;
    }

    .checkmark {
        color: green;
        font-size: 1.3rem;
    }

    .crossmark {
        color: red;
        font-size: 1.3rem;
    }
</style>

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 sidebar">
            <h4>Cursos</h4>
            <ul>
                <li class="active">Clases de Spinning</li>
                <li>Clases de Yoga</li>
                <li>Clases de Boxeo</li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="col-md-9 content">
            <h2 class="fw-bold mb-3" style="color:#FF6600;">Lista de Asistencia</h2>
            <p class="mb-4">Sandra Hernández, <span style="color:#FF6600;">¿qué deseas gestionar?</span></p>

            <div class="row mb-4">
                <div class="col-md-3">
                    <label class="form-label">Clase</label>
                    <select class="form-select">
                        <option>Spinning</option>
                        <option>Yoga</option>
                        <option>Boxeo</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Fecha</label>
                    <input type="date" class="form-control" value="2026-05-30">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Entrenador</label>
                    <select class="form-select">
                        <option>Diego Pérez</option>
                        <option>María Gómez</option>
                        <option>Carlos Ramírez</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-orange w-100">Buscar</button>
                </div>
            </div>

            <table class="table table-bordered text-center align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Fecha</th>
                        <th>Asistencia</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td>Camila Soto</td>
                        <td>30/05/2026 10:00 AM</td>
                        <td><span class="checkmark">✔</span></td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td>Rubén Jiménez</td>
                        <td>30/05/2026 10:00 AM</td>
                        <td><span class="checkmark">✔</span></td>
                    </tr>
                    <tr>
                        <td>3</td>
                        <td>Carolina Arias</td>
                        <td>30/05/2026 10:00 AM</td>
                        <td><span class="crossmark">✘</span></td>
                    </tr>
                    <tr>
                        <td>4</td>
                        <td>Erick Pérez</td>
                        <td>30/05/2026 10:00 AM</td>
                        <td><span class="checkmark">✔</span></td>
                    </tr>
                    <tr>
                        <td>5</td>
                        <td>Lucía Vargas</td>
                        <td>30/05/2026 10:00 AM</td>
                        <td><span class="checkmark">✔</span></td>
                    </tr>
                </tbody>
            </table>

            <div class="mt-3">
                <p><strong>Total inscritos:</strong> 5 &nbsp; | &nbsp; <strong>Presentes:</strong> 4 &nbsp; | &nbsp; <strong>Ausentes:</strong> 1</p>
                <button class="btn btn-orange">Ver detalles</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
