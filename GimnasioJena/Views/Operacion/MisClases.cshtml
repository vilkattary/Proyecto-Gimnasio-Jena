@{
    ViewBag.Title = "MisClases";
}

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        font-family: 'Oswald', sans-serif;
        background-color: #fff;
        color: #000;
    }

    .card-clase {
        background-color: #f9f9f9;
        border: 2px solid #FF6600;
        border-radius: 10px;
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .card-clase:hover {
            transform: translateY(-5px);
            box-shadow: 0 0 15px rgba(255, 102, 0, 0.4);
        }

        .card-clase img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-bottom: 2px solid #FF6600;
        }

    .card-body h5 {
        color: #FF6600;
        font-weight: 700;
    }

    .btn-orange {
        background-color: #FF6600;
        color: #fff;
        border: none;
        transition: 0.3s;
        border-radius: 5px;
        padding: 8px 20px;
    }

        .btn-orange:hover {
            background-color: #e65c00;
            transform: scale(1.05);
        }

    .divider {
        width: 100px;
        height: 4px;
        background: #FF6600;
        border-radius: 2px;
        margin: 0 auto;
    }
</style>

<section class="py-5">
    <div class="container text-center">
        <h1 class="fw-bold mb-2" style="font-size:3rem; letter-spacing:2px;">MIS CLASES</h1>
        <div class="divider mb-5"></div>

        <div class="row justify-content-center">
           
            <div class="col-md-3 mx-3 mb-4">
                <div class="card-clase">
                    <img src="https://images.unsplash.com/photo-1571019613914-85f342c55f9e" alt="Spinning">
                    <div class="card-body text-start p-3">
                        <h5>Clases de Spinning</h5>
                        <p class="mb-1"><strong>Profesor:</strong> Diego Pérez</p>
                        <p class="mb-1"><strong>Hora:</strong> 10:00 AM</p>
                        <p class="mb-3"><strong>Fecha:</strong> 30/05/2026</p>
                        <button class="btn btn-orange fw-semibold">Ver detalles</button>
                    </div>
                </div>
            </div>

         
            <div class="col-md-3 mx-3 mb-4">
                <div class="card-clase">
                    <img src="https://images.unsplash.com/photo-1605296867304-46d5465a13f1" alt="Yoga">
                    <div class="card-body text-start p-3">
                        <h5>Clases de Yoga</h5>
                        <p class="mb-1"><strong>Profesor:</strong> María Gómez</p>
                        <p class="mb-1"><strong>Hora:</strong> 5:00 PM</p>
                        <p class="mb-3"><strong>Fecha:</strong> 29/05/2026</p>
                        <button class="btn btn-orange fw-semibold">Ver detalles</button>
                    </div>
                </div>
            </div>

          
            <div class="col-md-3 mx-3 mb-4">
                <div class="card-clase">
                    <img src="https://images.unsplash.com/photo-1598970434795-0c54fe7c0642" alt="Boxeo">
                    <div class="card-body text-start p-3">
                        <h5>Clases de Boxeo</h5>
                        <p class="mb-1"><strong>Profesor:</strong> Carlos Ramírez</p>
                        <p class="mb-1"><strong>Hora:</strong> 7:00 PM</p>
                        <p class="mb-3"><strong>Fecha:</strong> 28/05/2026</p>
                        <button class="btn btn-orange fw-semibold">Ver detalles</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
