@{
    ViewBag.Title = "PanelMensajes";
}

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        font-family: 'Oswald', sans-serif;
        background-color: #111;
        color: #fff;
    }

    .message-list {
        background-color: #000;
        padding: 20px;
        height: 100vh;
        overflow-y: auto;
        border-right: 2px solid #FF6600;
    }

    .message-item {
        display: flex;
        align-items: center;
        padding: 15px;
        border-bottom: 1px solid #333;
        cursor: pointer;
        transition: 0.3s;
    }

        .message-item:hover {
            background-color: #222;
        }

        .message-item img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            margin-right: 15px;
            border: 2px solid #FF6600;
        }

        .message-item .name {
            font-weight: 700;
            color: #fff;
        }

        .message-item .preview {
            color: #bbb;
            font-size: 0.9rem;
        }

    .chat-window {
        background-color: #111;
        padding: 20px;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .chat-header {
        display: flex;
        align-items: center;
        border-bottom: 2px solid #FF6600;
        padding-bottom: 15px;
    }

        .chat-header img {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            margin-right: 15px;
            border: 3px solid #FF6600;
        }

        .chat-header h5 {
            color: #FF6600;
            margin: 0;
            font-size: 1.4rem;
        }

    .chat-body {
        flex-grow: 1;
        overflow-y: auto;
        margin-top: 20px;
    }

    .chat-message {
        margin-bottom: 20px;
    }

        .chat-message.sent {
            text-align: right;
        }

        .chat-message .bubble {
            display: inline-block;
            padding: 12px 18px;
            border-radius: 12px;
            max-width: 70%;
            font-size: 1rem;
        }

        .chat-message.received .bubble {
            background-color: #222;
            color: #fff;
        }

        .chat-message.sent .bubble {
            background-color: #FF6600;
            color: #fff;
        }

    .chat-footer {
        display: flex;
        align-items: center;
        border-top: 2px solid #FF6600;
        padding-top: 15px;
    }

        .chat-footer input {
            flex-grow: 1;
            background-color: #222;
            border: none;
            color: #fff;
            padding: 12px;
            border-radius: 8px;
        }

        .chat-footer button {
            background-color: #FF6600;
            color: #fff;
            border: none;
            padding: 12px 25px;
            margin-left: 10px;
            border-radius: 8px;
            font-weight: 600;
            transition: 0.3s;
        }

            .chat-footer button:hover {
                background-color: #e65c00;
                transform: scale(1.05);
            }
</style>

<div class="container-fluid">
    <div class="row">
      
        <div class="col-md-4 message-list">
            <div class="message-item">
                <img src="https://share.google/snfokBnq8hElY1WJ0" alt="Carlos López">
                <div>
                    <div class="name">Carlos López</div>
                    <div class="preview">¿Ofrecen descuentos para nuevos miembros?</div>
                </div>
                <div class="ms-auto text-muted" style="font-size:0.8rem;">10:55 AM</div>
            </div>

            <div class="message-item">
                <img src="https://share.google/snfokBnq8hElY1WJ0" alt="Susana Moreira">
                <div>
                    <div class="name">Susana Moreira</div>
                    <div class="preview">¿Me pueden pasar información sobre sus horarios?</div>
                </div>
                <div class="ms-auto text-muted" style="font-size:0.8rem;">9:23 AM</div>
            </div>

            <div class="message-item">
                <img src="https://share.google/snfokBnq8hElY1WJ0" alt="Miguel Castro">
                <div>
                    <div class="name">Miguel Castro</div>
                    <div class="preview">¿Tienen clases para principiantes?</div>
                </div>
                <div class="ms-auto text-muted" style="font-size:0.8rem;">8:15 AM</div>
            </div>
        </div>

      
        <div class="col-md-8 chat-window">
            <div class="chat-header">
                <img src="https://share.google/snfokBnq8hElY1WJ0" alt="Carlos López">
                <div>
                    <h5>Carlos López</h5>
                    <small>lopezcarlos@email.com</small>
                </div>
            </div>

            <div class="chat-body">
                <div class="chat-message received">
                    <div class="bubble">¿Ofrecen descuentos para nuevos miembros y cuál es el costo mensual?</div>
                </div>
                <div class="chat-message sent">
                    <div class="bubble">Sí, ofrecemos un descuento del 20% en la primera mensualidad para nuevos miembros.</div>
                </div>
                <div class="chat-message received">
                    <div class="bubble">¡Perfecto! Muchas gracias por la información.</div>
                </div>
            </div>

            <div class="chat-footer">
                <input type="text" placeholder="Escribe tu respuesta...">
                <button>Enviar</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
