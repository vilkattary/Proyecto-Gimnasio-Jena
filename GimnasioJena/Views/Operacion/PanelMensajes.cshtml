@{
    ViewBag.Title = "PanelMensajes";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<style>
    /* ============================================
       SISTEMA DE DISEÑO - GIMNASIO JENA
       ============================================ */
    :root {
        /* Colores Core */
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;

        /* Colores de Acento */
        --jena-orange: #FF6B35;
        --jena-dark-orange: #D95F31;

        /* Colores de Soporte */
        --jena-light-blue: #6C8EA4;
        --jena-white: #FFFFFF;
        --jena-light-gray: #F8F9FA;

        /* Tipografía */
        --font-primary: 'Montserrat', sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background: linear-gradient(180deg, var(--jena-white) 0%, var(--jena-light-gray) 100%);
        color: var(--jena-navy);
        min-height: 100vh;
    }

    /* ============================================
       SECCIÓN DE BIENVENIDA CON LOGO
       ============================================ */
    .welcome-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding: 20px;
        background-color: var(--jena-white);
        border-radius: 20px;
        border: 2px solid var(--jena-light-blue);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .logo-circular {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background-color: var(--jena-orange);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        flex-shrink: 0;
    }

        .logo-circular i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            position: absolute;
        }

        .logo-circular .letter-j {
            font-size: 5rem;
            color: var(--jena-dark-navy);
            font-weight: 800;
            font-family: var(--font-primary);
            position: relative;
            z-index: 1;
        }

    .welcome-text h3 {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .welcome-text p {
        color: var(--jena-light-blue);
        font-weight: 400;
        margin: 0;
    }

    /* ============================================
       TÍTULO PRINCIPAL
       ============================================ */
    .page-title {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 8px;
        position: relative;
        display: inline-block;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 5px;
            background-color: var(--jena-orange);
        }

    /* ===========================================
       LISTA DE MENSAJES (SIDEBAR)
       ============================================ */
    .message-list {
        background-color: var(--jena-dark-navy);
        padding: 25px 15px;
        min-height: calc(100vh - 40px);
        overflow-y: auto;
        border-radius: 20px 0 0 20px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
    }

        .message-list h5 {
            color: var(--jena-orange);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            font-size: 1.1rem;
            position: relative;
            padding-bottom: 12px;
        }

            .message-list h5::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                width: 60px;
                height: 3px;
                background-color: var(--jena-orange);
            }

    .message-item {
        display: flex;
        align-items: center;
        padding: 15px 12px;
        border-radius: 15px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.3s ease;
        background-color: rgba(255, 255, 255, 0.05);
        border: 2px solid transparent;
    }

        .message-item:hover {
            background-color: rgba(255, 107, 53, 0.15);
            border-color: var(--jena-orange);
            transform: translateX(8px);
        }

        .message-item.active {
            background-color: var(--jena-orange);
            border-color: var(--jena-dark-orange);
            box-shadow: 0 4px 15px rgba(255, 107, 53, 0.4);
        }

        .message-item img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            margin-right: 12px;
            border: 3px solid var(--jena-orange);
            object-fit: cover;
            flex-shrink: 0;
        }

        .message-item .avatar-placeholder {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            margin-right: 12px;
            border: 3px solid var(--jena-orange);
            background: linear-gradient(135deg, var(--jena-orange) 0%, var(--jena-dark-orange) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--jena-white);
            flex-shrink: 0;
        }

        .message-item .message-content {
            flex-grow: 1;
            min-width: 0;
        }

        .message-item .name {
            font-weight: 700;
            color: var(--jena-white);
            font-size: 0.95rem;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .message-item .preview {
            color: var(--jena-light-blue);
            font-size: 0.85rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .message-item.active .preview {
            color: var(--jena-white);
            opacity: 0.9;
        }

        .message-item .time {
            color: var(--jena-light-blue);
            font-size: 0.75rem;
            font-weight: 400;
            margin-left: 8px;
            white-space: nowrap;
        }

        .message-item.active .time {
            color: var(--jena-white);
            opacity: 0.8;
        }

    /* ============================================
       VENTANA DE CHAT
       ============================================ */
    .chat-window {
        background-color: var(--jena-white);
        padding: 25px;
        min-height: calc(100vh - 40px);
        display: flex;
        flex-direction: column;
        border-radius: 0 20px 20px 0;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .chat-header {
        display: flex;
        align-items: center;
        padding-bottom: 20px;
        border-bottom: 3px solid var(--jena-orange);
        margin-bottom: 25px;
    }

        .chat-header img {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            margin-right: 15px;
            border: 3px solid var(--jena-orange);
            object-fit: cover;
            box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
        }

        .chat-header .avatar-placeholder {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            margin-right: 15px;
            border: 3px solid var(--jena-orange);
            background: linear-gradient(135deg, var(--jena-orange) 0%, var(--jena-dark-orange) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 800;
            color: var(--jena-white);
            box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
        }

        .chat-header .user-info h5 {
            color: var(--jena-navy);
            margin: 0 0 5px 0;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: 1px;
        }

        .chat-header .user-info small {
            color: var(--jena-light-blue);
            font-weight: 600;
            font-size: 0.9rem;
        }

    .chat-body {
        flex-grow: 1;
        overflow-y: auto;
        padding: 20px 10px;
        margin-bottom: 20px;
        max-height: calc(100vh - 350px);
    }

        .chat-body::-webkit-scrollbar {
            width: 8px;
        }

        .chat-body::-webkit-scrollbar-track {
            background: var(--jena-light-gray);
            border-radius: 10px;
        }

        .chat-body::-webkit-scrollbar-thumb {
            background: var(--jena-orange);
            border-radius: 10px;
        }

            .chat-body::-webkit-scrollbar-thumb:hover {
                background: var(--jena-dark-orange);
            }

    .chat-message {
        margin-bottom: 20px;
        display: flex;
        align-items: flex-end;
        gap: 10px;
    }

        .chat-message.sent {
            justify-content: flex-end;
        }

        .chat-message.received {
            justify-content: flex-start;
        }

        .chat-message .bubble {
            padding: 14px 18px;
            border-radius: 18px;
            max-width: 70%;
            font-size: 0.95rem;
            line-height: 1.5;
            font-weight: 500;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            position: relative;
            word-wrap: break-word;
        }

        .chat-message.received .bubble {
            background-color: var(--jena-light-gray);
            color: var(--jena-navy);
            border: 2px solid var(--jena-light-blue);
            border-bottom-left-radius: 4px;
        }

        .chat-message.sent .bubble {
            background-color: var(--jena-white);
            color: var(--jena-navy);
            border: 2px solid var(--jena-orange);
            border-bottom-right-radius: 4px;
            font-weight: 500;
        }

        .chat-message .timestamp {
            font-size: 0.75rem;
            color: var(--jena-light-blue);
            align-self: flex-end;
            margin-bottom: 5px;
            font-weight: 400;
        }

    /* ============================================
       PIE DE CHAT (INPUT + BOTÓN)
       ============================================ */
    .chat-footer {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-top: 20px;
        border-top: 3px solid var(--jena-orange);
    }

        .chat-footer input {
            flex-grow: 1;
            background-color: var(--jena-light-gray);
            border: 2px solid var(--jena-light-blue);
            color: var(--jena-navy);
            padding: 14px 18px;
            border-radius: 50px;
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

            .chat-footer input::placeholder {
                color: var(--jena-light-blue);
            }

            .chat-footer input:focus {
                outline: none;
                border-color: var(--jena-orange);
                box-shadow: 0 0 0 0.25rem rgba(255, 107, 53, 0.15);
                background-color: var(--jena-white);
            }

        .chat-footer .btn-send {
            background-color: var(--jena-orange);
            color: var(--jena-white);
            border: none;
            padding: 14px 30px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
        }

            .chat-footer .btn-send:hover {
                background-color: var(--jena-dark-orange);
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
            }

            .chat-footer .btn-send:active {
                transform: translateY(-1px);
            }

    /* ============================================
       BADGE DE MENSAJES NO LEÍDOS
       ============================================ */
    .unread-badge {
        background-color: var(--jena-navy);
        color: var(--jena-white);
        font-size: 0.7rem;
        font-weight: 800;
        padding: 3px 8px;
        border-radius: 50px;
        margin-left: auto;
    }

      /* ============================================
       RESPONSIVE (MÓVILES < 768px)
       ============================================ */
    @@media (max-width: 768px) {
        .logo-circular {
            width: 120px;
            height: 120px;
        }

            .logo-circular i {
                font-size: 3rem;
            }

            .logo-circular .letter-j {
                font-size: 4rem;
            }

        .welcome-section {
            flex-direction: column;
            text-align: center;
            padding: 15px;
        }

        .page-title {
            font-size: 1.5rem;
            text-align: center;
            display: block;
        }

        .message-list {
            border-radius: 20px;
            margin-bottom: 1.5rem;
            min-height: 400px;
        }

        .chat-window {
            border-radius: 20px;
            min-height: 500px;
        }

        .chat-message .bubble {
            max-width: 85%;
            font-size: 0.9rem;
        }

        .chat-footer {
            flex-direction: column;
            gap: 10px;
        }

            .chat-footer input,
            .chat-footer .btn-send {
                width: 100%;
            }
    }

    /* ============================================
       ESTADO VACÍO DEL CHAT
       ============================================ */
    .empty-chat {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: var(--jena-light-blue);
        text-align: center;
        padding: 40px;
    }

        .empty-chat i {
            font-size: 5rem;
            color: var(--jena-orange);
            margin-bottom: 20px;
            opacity: 0.6;
        }

        .empty-chat h4 {
            color: var(--jena-navy);
            font-weight: 700;
            margin-bottom: 10px;
        }

        .empty-chat p {
            color: var(--jena-light-blue);
            font-weight: 400;
        }
</style>

<div class="container-fluid p-4">
    <!-- Sección de Bienvenida con Logo -->
    <div class="welcome-section">
        <div class="logo-circular">
            <i class="bi bi-tree"></i>
            <span class="letter-j">J</span>
        </div>
        <div class="welcome-text">
            <h3>Panel de Mensajería</h3>
            <p>Gestiona las consultas de tus clientes en tiempo real</p>
        </div>
    </div>

    <!-- Título Principal -->
    <div class="text-center mb-4">
        <h2 class="page-title">Mensajes y Consultas</h2>
    </div>

    <div class="row g-0">
        <!-- Lista de Mensajes (Sidebar) -->
        <div class="col-md-4">
            <div class="message-list">
                <h5><i class="bi bi-chat-dots-fill me-2"></i>Conversaciones</h5>

                <div class="message-item active">
                    <div class="avatar-placeholder">CL</div>
                    <div class="message-content">
                        <div class="name">Carlos López</div>
                        <div class="preview">¿Ofrecen descuentos para nuevos miembros?</div>
                    </div>
                    <div class="time">10:55 AM</div>
                </div>

                <div class="message-item">
                    <div class="avatar-placeholder">SM</div>
                    <div class="message-content">
                        <div class="name">Susana Moreira</div>
                        <div class="preview">¿Me pueden pasar información sobre sus horarios?</div>
                    </div>
                    <div class="time">9:23 AM</div>
                </div>

                <div class="message-item">
                    <div class="avatar-placeholder">MC</div>
                    <div class="message-content">
                        <div class="name">Miguel Castro</div>
                        <div class="preview">¿Tienen clases para principiantes?</div>
                    </div>
                    <div class="time">8:15 AM</div>
                    <span class="unread-badge">2</span>
                </div>

                <div class="message-item">
                    <div class="avatar-placeholder">LP</div>
                    <div class="message-content">
                        <div class="name">Laura Pérez</div>
                        <div class="preview">¿Cuál es el horario de las clases de spinning?</div>
                    </div>
                    <div class="time">Ayer</div>
                </div>

                <div class="message-item">
                    <div class="avatar-placeholder">JR</div>
                    <div class="message-content">
                        <div class="name">Javier Ramírez</div>
                        <div class="preview">Gracias por la información, me inscribo mañana.</div>
                    </div>
                    <div class="time">Ayer</div>
                </div>
            </div>
        </div>

        <!-- Ventana de Chat -->
        <div class="col-md-8">
            <div class="chat-window">
                <div class="chat-header">
                    <div class="avatar-placeholder">CL</div>
                    <div class="user-info">
                        <h5>Carlos López</h5>
                        <small><i class="bi bi-envelope-fill me-1"></i>lopezcarlos@email.com</small>
                    </div>
                </div>

                <div class="chat-body">
                    <div class="chat-message received">
                        <div class="bubble">
                            Hola, buen día. ¿Ofrecen descuentos para nuevos miembros y cuál es el costo mensual?
                        </div>
                        <div class="timestamp">10:52 AM</div>
                    </div>

                    <div class="chat-message sent">
                        <div class="timestamp">10:53 AM</div>
                        <div class="bubble">
                            ¡Hola Carlos! Sí, ofrecemos un descuento del 20% en la primera mensualidad para nuevos miembros. El costo regular es de $50 mensuales.
                        </div>
                    </div>

                    <div class="chat-message received">
                        <div class="bubble">
                            ¡Perfecto! Muchas gracias por la información. ¿Y qué incluye la membresía?
                        </div>
                        <div class="timestamp">10:54 AM</div>
                    </div>

                    <div class="chat-message sent">
                        <div class="timestamp">10:55 AM</div>
                        <div class="bubble">
                            La membresía incluye acceso ilimitado al gimnasio, todas nuestras clases grupales (Spinning, Yoga, Boxeo) y asesoría personalizada con nuestros entrenadores.
                        </div>
                    </div>

                    <div class="chat-message received">
                        <div class="bubble">
                            Excelente, me interesa. ¿Puedo pasar mañana para inscribirme?
                        </div>
                        <div class="timestamp">10:56 AM</div>
                    </div>
                </div>

                <div class="chat-footer">
                    <input type="text" placeholder="Escribe tu respuesta..." id="messageInput">
                    <button class="btn-send" onclick="sendMessage()">
                        <i class="bi bi-send-fill me-2"></i>Enviar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Función para enviar mensaje
    function sendMessage() {
        const input = document.getElementById('messageInput');
        const message = input.value.trim();

        if (message) {
            const chatBody = document.querySelector('.chat-body');
            const now = new Date();
            const time = now.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });

            const messageDiv = document.createElement('div');
            messageDiv.className = 'chat-message sent';
            messageDiv.innerHTML = `
                <div class="timestamp">${time}</div>
                <div class="bubble">${message}</div>
            `;

            chatBody.appendChild(messageDiv);
            chatBody.scrollTop = chatBody.scrollHeight;
            input.value = '';
        }
    }

    // Enviar con Enter
    document.getElementById('messageInput').addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            sendMessage();
        }
    });

    // Scroll automático al cargar
    window.addEventListener('DOMContentLoaded', function () {
        const chatBody = document.querySelector('.chat-body');
        if (chatBody) {
            chatBody.scrollTop = chatBody.scrollHeight;
        }
    });

    // Simular cambio de conversación
    document.querySelectorAll('.message-item').forEach(item => {
        item.addEventListener('click', function () {
            document.querySelectorAll('.message-item').forEach(i => i.classList.remove('active'));
            this.classList.add('active');

            // Aquí podrías cargar los mensajes de la conversación seleccionada
            const name = this.querySelector('.name').textContent;
            document.querySelector('.chat-header .user-info h5').textContent = name;
        });
    });
</script>