@{
    ViewBag.Title = "MisReservas";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />

<style>
    /* ============================================
       SISTEMA DE DISEÑO - GIMNASIO JENA
       ============================================ */
    :root {
        /* Colores Core */
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;
        /* Colores de Acento */
        --jena-orange: #FF6B35;
        --jena-dark-orange: #D95F31;
        /* Colores de Soporte */
        --jena-light-blue: #6C8EA4;
        --jena-white: #FFFFFF;
        --jena-light-gray: #F8F9FA;
        /* Tipografía */
        --font-primary: 'Montserrat', sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background: linear-gradient(180deg, var(--jena-white) 0%, var(--jena-light-gray) 100%);
        color: var(--jena-navy);
        min-height: 100vh;
    }

    /* ============================================
       SECCIÓN DE BIENVENIDA CON LOGO
       ============================================ */
    .welcome-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding: 20px;
        background-color: var(--jena-white);
        border-radius: 20px;
        border: 2px solid var(--jena-light-blue);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .logo-circular {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background-color: var(--jena-orange);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        flex-shrink: 0;
    }

        .logo-circular i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            position: absolute;
        }

        .logo-circular .letter-j {
            font-size: 5rem;
            color: var(--jena-dark-navy);
            font-weight: 800;
            font-family: var(--font-primary);
            position: relative;
            z-index: 1;
        }

    .welcome-text h3 {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .welcome-text p {
        color: var(--jena-light-blue);
        font-weight: 400;
        margin: 0;
    }

    /* ============================================
       TÍTULO PRINCIPAL
       ============================================ */
    .page-title {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 8px;
        position: relative;
        display: inline-block;
        font-size: 2.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 5px;
            background-color: var(--jena-orange);
        }

    /* ============================================
       CALENDARIO FULLCALENDAR - ESTILIZADO JENA
       ============================================ */
    .calendar-wrapper {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .calendar-wrapper::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 0;
            background-color: var(--jena-orange);
            transition: height 0.3s ease;
        }

        .calendar-wrapper:hover {
            border-color: var(--jena-orange);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.2);
        }

            .calendar-wrapper:hover::before {
                height: 5px;
            }

    #calendar {
        max-width: 100%;
        font-family: var(--font-primary);
    }

    /* Toolbar del calendario */
    .fc .fc-toolbar-title {
        color: var(--jena-navy) !important;
        font-weight: 800 !important;
        font-size: 1.6rem !important;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .fc .fc-button {
        background-color: var(--jena-orange) !important;
        border: none !important;
        color: var(--jena-white) !important;
        font-weight: 700 !important;
        border-radius: 10px !important;
        padding: 8px 15px !important;
        transition: all 0.3s ease !important;
    }

        .fc .fc-button:hover {
            background-color: var(--jena-dark-orange) !important;
            transform: translateY(-2px);
        }

        .fc .fc-button:disabled {
            opacity: 0.5 !important;
        }

    /* Días de la semana */
    .fc .fc-col-header-cell-cushion {
        color: var(--jena-navy) !important;
        font-weight: 700 !important;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
    }

    /* Números de día */
    .fc .fc-daygrid-day-number {
        color: var(--jena-orange) !important;
        font-weight: 700 !important;
        font-size: 1rem !important;
    }

    /* Celdas del calendario */
    .fc .fc-daygrid-day {
        background-color: var(--jena-white);
        transition: background-color 0.2s ease;
    }

        .fc .fc-daygrid-day:hover {
            background-color: rgba(255, 107, 53, 0.05);
        }

        .fc .fc-daygrid-day.fc-day-today {
            background-color: rgba(255, 107, 53, 0.1) !important;
        }

            .fc .fc-daygrid-day.fc-day-today .fc-daygrid-day-number {
                background-color: var(--jena-orange);
                color: var(--jena-white) !important;
                border-radius: 50%;
                width: 30px;
                height: 30px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

    /* Eventos en el calendario */
    .fc-event {
        background-color: var(--jena-orange) !important;
        border: none !important;
        border-radius: 8px !important;
        padding: 4px 8px !important;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .fc-event:hover {
            background-color: var(--jena-dark-orange) !important;
            transform: scale(1.05);
        }

    .fc-event-title {
        font-size: 0.8rem !important;
        color: var(--jena-white) !important;
        font-weight: 600 !important;
    }

    /* Bordes */
    .fc .fc-scrollgrid {
        border-color: var(--jena-light-blue) !important;
    }

        .fc .fc-scrollgrid td,
        .fc .fc-scrollgrid th {
            border-color: var(--jena-light-gray) !important;
        }

    /* ============================================
       CARDS DE RESERVAS
       ============================================ */
    .reservation-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        margin-bottom: 20px;
    }

        .reservation-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 0;
            background-color: var(--jena-orange);
            transition: height 0.3s ease;
        }

        .reservation-card:hover {
            border-color: var(--jena-orange);
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.25);
        }

            .reservation-card:hover::before {
                height: 5px;
            }

        .reservation-card .card-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--jena-orange) 0%, var(--jena-dark-orange) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(255, 107, 53, 0.3);
        }

            .reservation-card .card-icon i {
                font-size: 2rem;
                color: var(--jena-white);
            }

        .reservation-card h4 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 1.5rem;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .reservation-card .info-item {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
            color: var(--jena-navy);
            font-weight: 500;
        }

            .reservation-card .info-item i {
                color: var(--jena-orange);
                font-size: 1.1rem;
                margin-right: 12px;
                width: 20px;
            }

            .reservation-card .info-item strong {
                color: var(--jena-navy);
                margin-left: 5px;
                font-weight: 700;
            }

    /* ============================================
       BOTONES
       ============================================ */
    .btn-cancel {
        background-color: var(--jena-white);
        color: #dc3545;
        border: 2px solid #dc3545;
        border-radius: 50px;
        padding: 12px 28px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.15);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        justify-content: center;
    }

        .btn-cancel:hover {
            background-color: #dc3545;
            color: var(--jena-white);
            border-color: #dc3545;
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(220, 53, 69, 0.3);
        }

        .btn-cancel i {
            font-size: 1.1rem;
        }

    .btn-reserve-more {
        background-color: var(--jena-orange);
        color: var(--jena-white);
        border: none;
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-reserve-more:hover {
            background-color: var(--jena-dark-orange);
            color: var(--jena-white);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

    /* ============================================
       ESTADÍSTICAS
       ============================================ */
    .stats-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

        .stat-card:hover {
            border-color: var(--jena-orange);
            transform: translateY(-5px);
        }

        .stat-card i {
            font-size: 2.5rem;
            color: var(--jena-orange);
            margin-bottom: 10px;
        }

        .stat-card h3 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 2rem;
            margin-bottom: 5px;
        }

        .stat-card p {
            color: var(--jena-light-blue);
            font-weight: 600;
            font-size: 0.85rem;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    /* ============================================
       SECCIÓN DE HEADER
       ============================================ */
    .section-header {
        margin-bottom: 25px;
    }

        .section-header h5 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 1.3rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 10px;
            position: relative;
            padding-bottom: 10px;
        }

            .section-header h5::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                width: 60px;
                height: 3px;
                background-color: var(--jena-orange);
            }

        .section-header p {
            color: var(--jena-light-blue);
            font-weight: 500;
            margin: 0;
        }

    /* ============================================
       RESPONSIVE (MÓVILES < 768px)
       ============================================ */
    @@media (max-width: 768px) {
        .logo-circular {
            width: 120px;
            height: 120px;
        }

            .logo-circular i {
                font-size: 3rem;
            }

            .logo-circular .letter-j {
                font-size: 4rem;
            }

        .welcome-section {
            flex-direction: column;
            text-align: center;
            padding: 15px;
        }

        .page-title {
            font-size: 1.8rem;
            text-align: center;
            display: block;
        }

        .calendar-wrapper {
            padding: 15px;
            margin-bottom: 1.5rem;
        }

        .reservation-card {
            margin-bottom: 1.5rem;
        }

        #calendar {
            font-size: 0.85rem;
        }

        .fc .fc-toolbar-title {
            font-size: 1.2rem !important;
        }

        .fc .fc-button {
            padding: 6px 12px !important;
            font-size: 0.85rem !important;
        }
    }

    /* ============================================
       ESTADO VACÍO
       ============================================ */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background-color: var(--jena-white);
        border: 2px dashed var(--jena-light-blue);
        border-radius: 20px;
        margin: 30px 0;
    }

        .empty-state i {
            font-size: 4rem;
            color: var(--jena-orange);
            margin-bottom: 20px;
            opacity: 0.6;
        }

        .empty-state h4 {
            color: var(--jena-navy);
            font-weight: 700;
            margin-bottom: 10px;
        }

        .empty-state p {
            color: var(--jena-light-blue);
            margin-bottom: 25px;
        }
</style>

<div class="container-fluid p-4">
    <!-- Sección de Bienvenida con Logo -->
    <div class="welcome-section">
        <div class="logo-circular">
            <i class="bi bi-tree"></i>
            <span class="letter-j">J</span>
        </div>
        <div class="welcome-text">
            <h3>Mis Reservas</h3>
            <p>Gestiona y visualiza todas tus clases reservadas</p>
        </div>
    </div>

    <!-- Título Principal -->
    <div class="text-center mb-5">
        <h2 class="page-title">Calendario de Reservas</h2>
    </div>

    <!-- Estadísticas Rápidas -->
    <div class="stats-section">
        <div class="stat-card">
            <i class="bi bi-calendar-check"></i>
            <h3>2</h3>
            <p>Reservas Activas</p>
        </div>
        <div class="stat-card">
            <i class="bi bi-clock-history"></i>
            <h3>4</h3>
            <p>Clases Tomadas</p>
        </div>
        <div class="stat-card">
            <i class="bi bi-trophy"></i>
            <h3>100%</h3>
            <p>Asistencia</p>
        </div>
    </div>

    <div class="row">
        <!-- Columna del Calendario -->
        <div class="col-lg-6 mb-4">
            <div class="section-header">
                <h5><i class="bi bi-calendar3 me-2"></i>Vista Mensual</h5>
                <p>Selecciona una fecha para ver los detalles</p>
            </div>
            <div class="calendar-wrapper">
                <div id="calendar"></div>
            </div>
        </div>

        <!-- Columna de Reservas -->
        <div class="col-lg-6">
            <div class="section-header">
                <h5><i class="bi bi-bookmark-check me-2"></i>Próximas Clases</h5>
                <p>Tus reservas confirmadas</p>
            </div>

            <!-- Reserva 1: Spinning -->
            <div class="reservation-card">
                <div class="card-icon">
                    <i class="bi bi-bicycle"></i>
                </div>
                <h4>Clases de Spinning</h4>

                <div class="info-item">
                    <i class="bi bi-person-badge"></i>
                    <span>Instructor: <strong>Diego Pérez</strong></span>
                </div>

                <div class="info-item">
                    <i class="bi bi-calendar-event"></i>
                    <span>Fecha: <strong>30/04/2026</strong></span>
                </div>

                <div class="info-item">
                    <i class="bi bi-clock"></i>
                    <span>Hora: <strong>10:00 AM - 11:00 AM</strong></span>
                </div>

                <div class="info-item">
                    <i class="bi bi-geo-alt"></i>
                    <span>Lugar: <strong>Studio A, Costa Rica 🇨🇷</strong></span>
                </div>

                <div class="mt-3">
                    <a href="@Url.Action("EliminarReserva", "Clientes", new { id = 1 })"
                       class="btn btn-cancel"
                       onclick="return confirm('¿Estás seguro de cancelar esta reserva?')">
                        <i class="bi bi-x-circle"></i>
                        <span>Cancelar Reserva</span>
                    </a>
                </div>
            </div>

            <!-- Reserva 2: Yoga -->
            <div class="reservation-card">
                <div class="card-icon">
                    <i class="bi bi-heart-pulse"></i>
                </div>
                <h4>Clases de Yoga</h4>

                <div class="info-item">
                    <i class="bi bi-person-badge"></i>
                    <span>Instructor: <strong>María Gómez</strong></span>
                </div>

                <div class="info-item">
                    <i class="bi bi-calendar-event"></i>
                    <span>Fecha: <strong>29/04/2026</strong></span>
                </div>

                <div class="info-item">
                    <i class="bi bi-clock"></i>
                    <span>Hora: <strong>5:00 PM - 6:00 PM</strong></span>
                </div>

                <div class="info-item">
                    <i class="bi bi-geo-alt"></i>
                    <span>Lugar: <strong>Studio Zen, Costa Rica 🇨🇷</strong></span>
                </div>

                <div class="mt-3">
                    <a href="@Url.Action("EliminarReserva", "Clientes", new { id = 2 })"
                       class="btn btn-cancel"
                       onclick="return confirm('¿Estás seguro de cancelar esta reserva?')">
                        <i class="bi bi-x-circle"></i>
                        <span>Cancelar Reserva</span>
                    </a>
                </div>
            </div>

            <!-- Botón para Reservar Más -->
            <div class="text-center mt-4">
                <a href="@Url.Action("ReservarClases", "Clientes")" class="btn btn-reserve-more">
                    <i class="bi bi-calendar-plus"></i>
                    <span>Reservar Más Clases</span>
                </a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'es',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth'
            },
            buttonText: {
                today: 'Hoy',
                month: 'Mes'
            },
            events: [
                {
                    title: 'Yoga',
                    start: '2026-04-29',
                    color: '#FF6B35',
                    icon: 'heart-pulse'
                },
                {
                    title: 'Spinning',
                    start: '2026-04-30',
                    color: '#FF6B35',
                    icon: 'bicycle'
                }
            ],
            eventClick: function (info) {
                alert('Clase: ' + info.event.title + '\nFecha: ' + info.event.start.toLocaleDateString('es-ES'));
            }
        });
        calendar.render();
    });
</script>