@{
    ViewBag.Title = "MiPerfil";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<style>
    /* ============================================
       SISTEMA DE DISEÑO - GIMNASIO JENA
       ============================================ */
    :root {
        /* Colores Core */
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;
        /* Colores de Acento */
        --jena-orange: #FF6B35;
        --jena-dark-orange: #D95F31;
        /* Colores de Soporte */
        --jena-light-blue: #6C8EA4;
        --jena-white: #FFFFFF;
        --jena-light-gray: #F8F9FA;
        /* Tipografía */
        --font-primary: 'Montserrat', sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background: linear-gradient(180deg, var(--jena-white) 0%, var(--jena-light-gray) 100%);
        color: var(--jena-navy);
        min-height: 100vh;
    }

    /* ============================================
       SECCIÓN DE BIENVENIDA CON LOGO
       ============================================ */
    .welcome-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding: 20px;
        background-color: var(--jena-white);
        border-radius: 20px;
        border: 2px solid var(--jena-light-blue);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .logo-circular {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background-color: var(--jena-orange);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        flex-shrink: 0;
    }

        .logo-circular i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            position: absolute;
        }

        .logo-circular .letter-j {
            font-size: 5rem;
            color: var(--jena-dark-navy);
            font-weight: 800;
            font-family: var(--font-primary);
            position: relative;
            z-index: 1;
        }

    .welcome-text h3 {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .welcome-text p {
        color: var(--jena-light-blue);
        font-weight: 400;
        margin: 0;
    }

    /* ============================================
       TÍTULO PRINCIPAL
       ============================================ */
    .page-title {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 8px;
        position: relative;
        display: inline-block;
        font-size: 2.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 5px;
            background-color: var(--jena-orange);
        }

    /* ============================================
       AVATAR DE PERFIL (SIN IMAGEN EXTERNA)
       ============================================ */
    .profile-avatar {
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--jena-orange) 0%, var(--jena-dark-orange) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 5rem;
        font-weight: 800;
        color: var(--jena-white);
        border: 5px solid var(--jena-orange);
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
    }

        .profile-avatar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, transparent 0%, rgba(255, 255, 255, 0.1) 100%);
        }

        .profile-avatar .initials {
            position: relative;
            z-index: 1;
        }

        .profile-avatar .verified-badge {
            position: absolute;
            bottom: 10px;
            right: 10px;
            background-color: var(--jena-white);
            color: var(--jena-orange);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            border: 3px solid var(--jena-orange);
            z-index: 2;
        }

    /* ============================================
       CARD DE INFORMACIÓN
       ============================================ */
    .info-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        margin-bottom: 30px;
    }

        .info-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 0;
            background-color: var(--jena-orange);
            transition: height 0.3s ease;
        }

        .info-card:hover {
            border-color: var(--jena-orange);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.2);
        }

            .info-card:hover::before {
                height: 5px;
            }

    .info-item {
        display: flex;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--jena-light-gray);
    }

        .info-item:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: none;
        }

        .info-item i {
            font-size: 1.8rem;
            color: var(--jena-orange);
            margin-right: 15px;
            width: 40px;
            flex-shrink: 0;
        }

        .info-item .info-content {
            flex-grow: 1;
        }

        .info-item .info-label {
            color: var(--jena-light-blue);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .info-item .info-value {
            color: var(--jena-navy);
            font-weight: 700;
            font-size: 1.1rem;
        }

    /* ============================================
       DESCRIPCIÓN
       ============================================ */
    .description-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        margin-bottom: 30px;
    }

        .description-card h5 {
            color: var(--jena-navy);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 15px;
            position: relative;
            padding-bottom: 12px;
        }

            .description-card h5::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                width: 60px;
                height: 3px;
                background-color: var(--jena-orange);
            }

        .description-card p {
            color: var(--jena-navy);
            line-height: 1.8;
            font-weight: 400;
            margin: 0;
        }

    /* ============================================
       BOTONES DE ACCIÓN
       ============================================ */
    .action-buttons-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        margin-bottom: 30px;
    }

        .action-buttons-card h5 {
            color: var(--jena-navy);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            text-align: center;
            position: relative;
            padding-bottom: 12px;
        }

            .action-buttons-card h5::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 3px;
                background-color: var(--jena-orange);
            }

    .btn-action {
        background-color: var(--jena-white);
        color: var(--jena-navy);
        border: 2px solid var(--jena-orange);
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.15);
        width: 100%;
        margin-bottom: 15px;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-action:last-child {
            margin-bottom: 0;
        }

        .btn-action:hover {
            background-color: var(--jena-orange);
            color: var(--jena-white);
            border-color: var(--jena-orange);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

        .btn-action:active {
            transform: translateY(-1px);
        }

        .btn-action i {
            font-size: 1.2rem;
            color: var(--jena-orange);
            transition: color 0.3s ease;
        }

        .btn-action:hover i {
            color: var(--jena-white);
        }

    /* ============================================
       ESTADÍSTICAS RÁPIDAS
       ============================================ */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

        .stat-card:hover {
            border-color: var(--jena-orange);
            transform: translateY(-5px);
        }

        .stat-card i {
            font-size: 3rem;
            color: var(--jena-orange);
            margin-bottom: 15px;
        }

        .stat-card h3 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 2rem;
            margin-bottom: 8px;
        }

        .stat-card p {
            color: var(--jena-light-blue);
            font-weight: 600;
            font-size: 0.9rem;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    /* ============================================
       RESPONSIVE (MÓVILES < 768px)
       ============================================ */
    @@media (max-width: 768px) {
        .logo-circular {
            width: 120px;
            height: 120px;
        }

            .logo-circular i {
                font-size: 3rem;
            }

            .logo-circular .letter-j {
                font-size: 4rem;
            }

        .welcome-section {
            flex-direction: column;
            text-align: center;
            padding: 15px;
        }

        .page-title {
            font-size: 1.8rem;
            text-align: center;
            display: block;
        }

        .profile-avatar {
            width: 150px;
            height: 150px;
            font-size: 4rem;
            margin: 0 auto 20px;
        }

        .info-card,
        .description-card,
        .action-buttons-card {
            margin-bottom: 1.5rem;
        }

        .profile-section {
            text-align: center;
        }

        .info-item {
            flex-direction: column;
            text-align: center;
        }

            .info-item i {
                margin-right: 0;
                margin-bottom: 10px;
            }

        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container-fluid p-4">
    <!-- Sección de Bienvenida con Logo -->
    <div class="welcome-section">
        <div class="logo-circular">
            <i class="bi bi-tree"></i>
            <span class="letter-j">J</span>
        </div>
        <div class="welcome-text">
            <h3>Mi Perfil Personal</h3>
            <p>Gestiona tu información y preferencias del gimnasio</p>
        </div>
    </div>

    <!-- Título Principal -->
    <div class="text-center mb-5">
        <h2 class="page-title">Mi Perfil</h2>
    </div>

    <!-- Estadísticas del Usuario -->
    <div class="stats-grid">
        <div class="stat-card">
            <i class="bi bi-calendar-check"></i>
            <h3>15</h3>
            <p>Clases Tomadas</p>
        </div>
        <div class="stat-card">
            <i class="bi bi-trophy"></i>
            <h3>3</h3>
            <p>Logros</p>
        </div>
        <div class="stat-card">
            <i class="bi bi-star-fill"></i>
            <h3>Gold</h3>
            <p>Membresía</p>
        </div>
    </div>

    <div class="row">
        <!-- Columna Izquierda: Avatar e Información -->
        <div class="col-lg-7 mb-4">
            <!-- Avatar y Datos Principales -->
            <div class="info-card">
                <div class="row">
                    <div class="col-md-4 profile-section mb-3 mb-md-0">
                        <div class="profile-avatar mx-auto">
                            <span class="initials">JM</span>
                            <div class="verified-badge">
                                <i class="bi bi-check-lg"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="info-item">
                            <i class="bi bi-person-circle"></i>
                            <div class="info-content">
                                <div class="info-label">Nombre Completo</div>
                                <div class="info-value">Jonás Martínez</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-envelope"></i>
                            <div class="info-content">
                                <div class="info-label">Correo Electrónico</div>
                                <div class="info-value">jonas@example.com</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-telephone"></i>
                            <div class="info-content">
                                <div class="info-label">Teléfono</div>
                                <div class="info-value">+506 8888-8888</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-geo-alt"></i>
                            <div class="info-content">
                                <div class="info-label">Dirección</div>
                                <div class="info-value">San José, Costa Rica</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Descripción -->
            <div class="description-card">
                <h5><i class="bi bi-info-circle me-2"></i>Sobre Mí</h5>
                <p>
                    Apasionado por el fitness y el bienestar. Disfruto ayudando a otros a alcanzar sus metas.
                    Me especializo en entrenamiento de fuerza y resistencia. Creo firmemente que la constancia
                    y la disciplina son las claves del éxito en cualquier objetivo físico.
                </p>
            </div>
        </div>

        <!-- Columna Derecha: Acciones Rápidas -->
        <div class="col-lg-5">
            <div class="action-buttons-card">
                <h5><i class="bi bi-lightning-charge me-2"></i>Acciones Rápidas</h5>

                <a href="@Url.Action("MiMembresia", "Clientes")" class="btn btn-action">
                    <i class="bi bi-credit-card"></i>
                    <span>Mi Membresía</span>
                </a>

                <a href="@Url.Action("ReservarClases", "Clientes")" class="btn btn-action">
                    <i class="bi bi-calendar-plus"></i>
                    <span>Reservar Clase</span>
                </a>

                <a href="@Url.Action("MisReservas", "Clientes")" class="btn btn-action">
                    <i class="bi bi-list-check"></i>
                    <span>Mis Reservas</span>
                </a>

                <a href="@Url.Action("EditarPerfil", "Clientes")" class="btn btn-action">
                    <i class="bi bi-pencil-square"></i>
                    <span>Editar Perfil</span>
                </a>

                <a href="@Url.Action("Configuracion", "Clientes")" class="btn btn-action">
                    <i class="bi bi-gear"></i>
                    <span>Configuración</span>
                </a>
            </div>

            <!-- Card de Membresía Activa -->
            <div class="info-card">
                <h5 class="text-center mb-3" style="color: var(--jena-navy); font-weight: 800;">
                    <i class="bi bi-star-fill" style="color: var(--jena-orange);"></i>
                    Membresía Activa
                </h5>
                <div class="text-center">
                    <div class="mb-3">
                        <span style="font-size: 2rem; font-weight: 800; color: var(--jena-orange);">GOLD</span>
                    </div>
                    <div class="info-item justify-content-center" style="border: none; padding: 0;">
                        <i class="bi bi-calendar-event"></i>
                        <div class="info-content" style="text-align: center;">
                            <div class="info-label">Válida Hasta</div>
                            <div class="info-value">31/12/2026</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>