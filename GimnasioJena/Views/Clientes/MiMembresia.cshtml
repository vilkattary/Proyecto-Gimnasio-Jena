@{
    ViewBag.Title = "MiMembresia";
}


<section style="background: linear-gradient(135deg, #111111 60%, #2c2c2c 100%); min-height: 60vh;" class="d-flex align-items-center">
    <div class="container text-center py-5">
        <h1 class="fw-bold text-white mb-3" style="font-size:2.8rem; font-family:'Oswald',sans-serif;">
            MI MEMBRESÍA
        </h1>
        <div class="mx-auto mb-4" style="width:80px; height:4px; background:#FF6600; border-radius:2px;"></div>

        <div class="p-4 rounded shadow-lg d-inline-block" style="background:#1a1a1a; border:3px solid #FF6600; max-width:600px;">
            <h2 class="fw-bold text-white mb-2" style="font-family:'Oswald',sans-serif;">Plan Salud</h2>
            <p class="text-light mb-2">Acceso ilimitado a clases, casillero diario, evaluación física y 1 sesión PT.</p>
            <p class="text-secondary small mb-0">Próxima renovación: 6/5/2026</p>
            <h4 class="fw-bold mt-3" style="color:#FF6600;">₡25,000 / mes</h4>
        </div>
    </div>
</section>


<section class="py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <p class="text-uppercase mb-1" style="color:#FF6600; font-family:'Oswald',sans-serif; letter-spacing:3px;">Opciones disponibles</p>
            <h2 class="fw-bold display-5" style="color:#111;">OTRAS MEMBRESÍAS</h2>
            <div class="mx-auto mt-2" style="width:60px; height:4px; background:#FF6600; border-radius:2px;"></div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4" style="border-top:4px solid #FF6600 !important;">
                    <h4 class="fw-bold" style="font-family:'Oswald',sans-serif; color:#111;">Salud Más</h4>
                    <p class="text-muted">Incluye servicio de lavandería, casillero nocturno y 3 sesiones PT.</p>
                    <h5 class="fw-bold mb-3" style="color:#FF6600;">₡35,000 / mes</h5>
                    <a href="#" class="btn btn-dark fw-semibold" style="color:#FF6600;">Consultar tarifas</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4" style="border-top:4px solid #FF6600 !important;">
                    <h4 class="fw-bold" style="font-family:'Oswald',sans-serif; color:#111;">Corporativo</h4>
                    <p class="text-muted">Acceso grupal, beneficios para empleados y pases de invitado.</p>
                    <h5 class="fw-bold mb-3" style="color:#FF6600;">₡50,000 / mes</h5>
                    <a href="#" class="btn btn-dark fw-semibold" style="color:#FF6600;">Aprende más</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4" style="border-top:4px solid #FF6600 !important;">
                    <h4 class="fw-bold" style="font-family:'Oswald',sans-serif; color:#111;">Estudiante</h4>
                    <p class="text-muted">Descuento especial, acceso completo y pases de invitado.</p>
                    <h5 class="fw-bold mb-3" style="color:#FF6600;">₡15,000 / mes</h5>
                    <a href="#" class="btn btn-dark fw-semibold" style="color:#FF6600;">Consultar tarifas</a>
                </div>
            </div>
        </div>
    </div>
</section>
