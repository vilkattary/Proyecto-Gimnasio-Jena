@{
    ViewBag.Title = "MisClases";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<style>
    /* ============================================
       SISTEMA DE DISEÑO - GIMNASIO JENA
       ============================================ */
    :root {
        /* Colores Core */
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;
        /* Colores de Acento */
        --jena-orange: #FF6B35;
        --jena-dark-orange: #D95F31;
        /* Colores de Soporte */
        --jena-light-blue: #6C8EA4;
        --jena-white: #FFFFFF;
        --jena-light-gray: #F8F9FA;
        /* Tipografía */
        --font-primary: 'Montserrat', sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background: linear-gradient(180deg, var(--jena-white) 0%, var(--jena-light-gray) 100%);
        color: var(--jena-navy);
        min-height: 100vh;
    }

    /* ============================================
       SECCIÓN DE BIENVENIDA CON LOGO
       ============================================ */
    .welcome-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding: 20px;
        background-color: var(--jena-white);
        border-radius: 20px;
        border: 2px solid var(--jena-light-blue);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .logo-circular {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background-color: var(--jena-orange);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        flex-shrink: 0;
    }

        .logo-circular i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            position: absolute;
        }

        .logo-circular .letter-j {
            font-size: 5rem;
            color: var(--jena-dark-navy);
            font-weight: 800;
            font-family: var(--font-primary);
            position: relative;
            z-index: 1;
        }

    .welcome-text h3 {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .welcome-text p {
        color: var(--jena-light-blue);
        font-weight: 400;
        margin: 0;
    }

    /* ============================================
       TÍTULO PRINCIPAL
       ============================================ */
    .page-title {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 8px;
        position: relative;
        display: inline-block;
        font-size: 2.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 5px;
            background-color: var(--jena-orange);
        }

    /* ============================================
       CARDS DE CLASES
       ============================================ */
    .card-clase {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .card-clase::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 0;
            background-color: var(--jena-orange);
            transition: height 0.3s ease;
            z-index: 1;
        }

        .card-clase:hover {
            border-color: var(--jena-orange);
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.25);
        }

            .card-clase:hover::before {
                height: 5px;
            }

    /* ============================================
       PLACEHOLDER DE IMAGEN (SIN IMÁGENES EXTERNAS)
       ============================================ */
    .card-image-placeholder {
        width: 100%;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .card-image-placeholder.spinning {
            background: linear-gradient(135deg, var(--jena-orange) 0%, var(--jena-dark-orange) 100%);
        }

        .card-image-placeholder.yoga {
            background: linear-gradient(135deg, var(--jena-light-blue) 0%, var(--jena-navy) 100%);
        }

        .card-image-placeholder.boxeo {
            background: linear-gradient(135deg, var(--jena-dark-navy) 0%, var(--jena-navy) 100%);
        }

        .card-image-placeholder i {
            font-size: 5rem;
            color: rgba(255, 255, 255, 0.9);
            z-index: 1;
        }

        .card-image-placeholder::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: var(--jena-orange);
        }

    /* ============================================
       CUERPO DE LA CARD
       ============================================ */
    .card-clase .card-body {
        padding: 25px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

        .card-clase .card-body h5 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 1.3rem;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .card-clase .card-body .info-item {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
            color: var(--jena-navy);
            font-weight: 500;
        }

            .card-clase .card-body .info-item i {
                color: var(--jena-orange);
                font-size: 1.1rem;
                margin-right: 10px;
                width: 20px;
            }

            .card-clase .card-body .info-item strong {
                color: var(--jena-navy);
                margin-right: 5px;
            }

    /* ============================================
       BOTONES ESTILO PÍLDORA
       ============================================ */
    .btn-orange {
        background-color: var(--jena-orange);
        color: var(--jena-white);
        border: none;
        border-radius: 50px;
        padding: 12px 28px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
        margin-top: auto;
        width: 100%;
    }

        .btn-orange:hover {
            background-color: var(--jena-dark-orange);
            color: var(--jena-white);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

        .btn-orange:active {
            transform: translateY(-1px);
        }
    /* ============================================
BOTONES DE ACCIÓN
============================================ */
    .action-buttons-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        margin-bottom: 30px;
    }

        .action-buttons-card h5 {
            color: var(--jena-navy);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            text-align: center;
            position: relative;
            padding-bottom: 12px;
        }

            .action-buttons-card h5::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 3px;
                background-color: var(--jena-orange);
            }

    .btn-action {
        background-color: var(--jena-white);
        color: var(--jena-navy);
        border: 2px solid var(--jena-orange);
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.15);
        width: 100%;
        margin-bottom: 15px;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-action:last-child {
            margin-bottom: 0;
        }

        .btn-action:hover {
            background-color: var(--jena-orange);
            color: var(--jena-white);
            border-color: var(--jena-orange);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

        .btn-action:active {
            transform: translateY(-1px);
        }

        .btn-action i {
            font-size: 1.2rem;
            color: var(--jena-orange);
            transition: color 0.3s ease;
        }

        .btn-action:hover i {
            color: var(--jena-white);
        }

    /* ============================================
       BADGE DE ESTADO
       ============================================ */
    .status-badge {
        display: inline-block;
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 15px;
    }

        .status-badge.active {
            background-color: rgba(255, 107, 53, 0.15);
            color: var(--jena-orange);
            border: 2px solid var(--jena-orange);
        }

        .status-badge.upcoming {
            background-color: rgba(108, 142, 164, 0.15);
            color: var(--jena-light-blue);
            border: 2px solid var(--jena-light-blue);
        }

    /* ============================================
       RESPONSIVE (MÓVILES < 768px)
       ============================================ */
    @@media (max-width: 768px) {
        .logo-circular {
            width: 120px;
            height: 120px;
        }

            .logo-circular i {
                font-size: 3rem;
            }

            .logo-circular .letter-j {
                font-size: 4rem;
            }

        .welcome-section {
            flex-direction: column;
            text-align: center;
            padding: 15px;
        }

        .page-title {
            font-size: 1.8rem;
            text-align: center;
            display: block;
        }

        .card-clase {
            margin-bottom: 1.5rem;
        }

        .card-image-placeholder {
            height: 150px;
        }

            .card-image-placeholder i {
                font-size: 3.5rem;
            }

        .card-clase .card-body {
            padding: 20px;
        }

            .card-clase .card-body h5 {
                font-size: 1.1rem;
            }
    }

    /* ============================================
       SECCIÓN DE ESTADÍSTICAS
       ============================================ */
    .stats-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        margin-bottom: 30px;
    }

        .stats-card i {
            font-size: 3rem;
            color: var(--jena-orange);
            margin-bottom: 15px;
        }

        .stats-card h3 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 2.5rem;
            margin-bottom: 8px;
        }

        .stats-card p {
            color: var(--jena-light-blue);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
</style>

<div class="container-fluid p-4">
    <!-- Sección de Bienvenida con Logo -->
    <div class="welcome-section">
        <div class="logo-circular">
            <i class="bi bi-tree"></i>
            <span class="letter-j">J</span>
        </div>
        <div class="welcome-text">
            <h3>Mis Clases Programadas</h3>
            <p>Gestiona y visualiza todas tus clases inscritas</p>
        </div>
    </div>

    <!-- Título Principal -->
    <div class="text-center mb-5">
        <h2 class="page-title">Mis Clases</h2>
    </div>

    <!-- Estadísticas Rápidas -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <i class="bi bi-calendar-check"></i>
                <h3>3</h3>
                <p>Clases Activas</p>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <i class="bi bi-clock-history"></i>
                <h3>12</h3>
                <p>Horas Totales</p>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <i class="bi bi-trophy"></i>
                <h3>85%</h3>
                <p>Asistencia</p>
            </div>
        </div>
    </div>

    <!-- Grid de Clases -->
    <div class="row justify-content-center">
        <!-- Clase 1: Spinning -->
        <div class="col-md-4 mb-4">
            <div class="card-clase">
                <div class="card-image-placeholder spinning">
                    <i class="bi bi-bicycle"></i>
                </div>
                <div class="card-body">
                    <span class="status-badge active">En curso</span>
                    <h5>Clases de Spinning</h5>

                    <div class="info-item">
                        <i class="bi bi-person-badge"></i>
                        <span><strong>Profesor:</strong> Diego Pérez</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-clock"></i>
                        <span><strong>Hora:</strong> 10:00 AM</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-calendar-event"></i>
                        <span><strong>Fecha:</strong> 30/05/2026</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-geo-alt"></i>
                        <span><strong>Sala:</strong> Studio A</span>
                    </div>

                    <button class="btn btn-action mt-3">
                        <i class="bi bi-eye me-2"></i>Ver detalles
                    </button>
                </div>
            </div>
        </div>

        <!-- Clase 2: Yoga -->
        <div class="col-md-4 mb-4">
            <div class="card-clase">
                <div class="card-image-placeholder yoga">
                    <i class="bi bi-heart-pulse"></i>
                </div>
                <div class="card-body">
                    <span class="status-badge upcoming">Próxima</span>
                    <h5>Clases de Yoga</h5>

                    <div class="info-item">
                        <i class="bi bi-person-badge"></i>
                        <span><strong>Profesor:</strong> María Gómez</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-clock"></i>
                        <span><strong>Hora:</strong> 5:00 PM</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-calendar-event"></i>
                        <span><strong>Fecha:</strong> 29/05/2026</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-geo-alt"></i>
                        <span><strong>Sala:</strong> Studio Zen</span>
                    </div>

                    <button class="btn btn-action mt-3">
                        <i class="bi bi-eye me-2"></i>Ver detalles
                    </button>
                </div>
            </div>
        </div>

        <!-- Clase 3: Boxeo -->
        <div class="col-md-4 mb-4">
            <div class="card-clase">
                <div class="card-image-placeholder boxeo">
                    <i class="bi bi-trophy"></i>
                </div>
                <div class="card-body">
                    <span class="status-badge upcoming">Próxima</span>
                    <h5>Clases de Boxeo</h5>

                    <div class="info-item">
                        <i class="bi bi-person-badge"></i>
                        <span><strong>Profesor:</strong> Carlos Ramírez</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-clock"></i>
                        <span><strong>Hora:</strong> 7:00 PM</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-calendar-event"></i>
                        <span><strong>Fecha:</strong> 28/05/2026</span>
                    </div>

                    <div class="info-item">
                        <i class="bi bi-geo-alt"></i>
                        <span><strong>Sala:</strong> Ring Principal</span>
                    </div>

                    <button class="btn btn-action mt-3">
                        <i class="bi bi-eye me-2"></i>Ver detalles
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>