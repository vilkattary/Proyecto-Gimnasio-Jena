@model GimnasioJena.Abstracciones.Modelos.Clases.ClaseCrearDto

@{
    ViewBag.Title = "Registrar Clase";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/Content/estilo/estilo.css" />

<div class="container py-5">

    <div class="text-center mb-5">
        <div class="d-flex justify-content-center align-items-center mb-3">
            <div style="width:60px;height:60px;border-radius:50%;
                        background-color:var(--jena-orange);
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        margin-right:20px;
                        box-shadow:0 4px 15px rgba(255,107,53,0.4);">
                <i class="bi bi-calendar3" style="font-size:1.8rem;color:#fff;"></i>
            </div>

            <h1 class="page-title mb-0">Registrar Clase</h1>
        </div>
    </div>

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensajeError"]
        </div>
    }

    @using (Html.BeginForm("RegistrarClase", "Clases", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
    {
        @Html.AntiForgeryToken()

        <div class="row g-4">

            <div class="col-lg-7">
                <div class="info-card">

                    <h5 class="mb-4">
                        <i class="bi bi-list-check me-2" style="color:var(--jena-orange);"></i>
                        Datos de la Clase
                    </h5>

                    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="info-label">Tipo de clase</label>
                            @Html.DropDownListFor(
                                m => m.idTipoClase,
                                (SelectList)ViewBag.TiposClase,
                                "Seleccione un tipo de clase",
                                new { @class = "form-control mt-1" }
                            )
                            @Html.ValidationMessageFor(m => m.idTipoClase, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="info-label">Estado</label>
                            @Html.DropDownListFor(
                                m => m.idEstadoClase,
                                (SelectList)ViewBag.EstadosClase,
                                "Seleccione un estado",
                                new { @class = "form-control mt-1" }
                            )
                            @Html.ValidationMessageFor(m => m.idEstadoClase, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="info-label">Entrenador</label>
                        @Html.DropDownListFor(
                            m => m.idUsuarioEntrenador,
                            (SelectList)ViewBag.Entrenadores,
                            "Seleccione un entrenador",
                            new { @class = "form-control mt-1" }
                        )
                        @Html.ValidationMessageFor(m => m.idUsuarioEntrenador, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-4">
                        @Html.LabelFor(m => m.fechaClase, "Fecha de la clase", new { @class = "info-label" })
                        @Html.TextBoxFor(m => m.fechaClase, "{0:yyyy-MM-dd}", new { @class = "form-control mt-1", type = "date" })
                        @Html.ValidationMessageFor(m => m.fechaClase, "", new { @class = "text-danger small" })
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            @Html.LabelFor(m => m.horaInicio, "Hora de inicio", new { @class = "info-label" })
                            @Html.TextBoxFor(m => m.horaInicio, new { @class = "form-control mt-1", type = "time" })
                            @Html.ValidationMessageFor(m => m.horaInicio, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.horaFin, "Hora de finalización", new { @class = "info-label" })
                            @Html.TextBoxFor(m => m.horaFin, new { @class = "form-control mt-1", type = "time" })
                            @Html.ValidationMessageFor(m => m.horaFin, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            @Html.LabelFor(m => m.cupoMaximo, "Cupo máximo", new { @class = "info-label" })
                            @Html.TextBoxFor(m => m.cupoMaximo, new
                            {
                                @class = "form-control mt-1",
                                type = "number",
                                min = "1",
                                max = "12",
                                placeholder = "12"
                            })
                            @Html.ValidationMessageFor(m => m.cupoMaximo, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-8">
                            @Html.LabelFor(m => m.ubicacion, "Ubicación", new { @class = "info-label" })
                            @Html.TextBoxFor(m => m.ubicacion, new
                            {
                                @class = "form-control mt-1",
                                placeholder = "Sala principal"
                            })
                            @Html.ValidationMessageFor(m => m.ubicacion, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-lg-5">
                <div class="description-card mb-4">
                    <h5>Información Adicional</h5>

                    <div class="mt-3">
                        @Html.LabelFor(m => m.observaciones, "Observaciones", new { @class = "info-label mb-2 d-block" })
                        @Html.TextAreaFor(m => m.observaciones, new
                        {
                            @class = "form-control",
                            rows = "10",
                            placeholder = "Escribe alguna observación o detalle adicional sobre la clase...",
                            style = "resize:vertical;border-radius:12px;"
                        })
                        @Html.ValidationMessageFor(m => m.observaciones, "", new { @class = "text-danger small" })
                    </div>
                </div>

                <button type="submit" class="btn-orange w-100"
                        style="font-size:1rem; letter-spacing:1px; padding:16px 30px; border-radius:50px;">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    Registrar Clase
                </button>

                <div class="text-center mt-4">
                    <a href="@Url.Action("ObtenerTodasLasClases")" class="text-muted text-decoration-none">
                        ← Volver al listado
                    </a>
                </div>
            </div>

        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}