<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Jéna Training Methodology</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <link href="@(Url.Content("~/Content/estilo/estilo.css"))?v=5" rel="stylesheet" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-apex fixed-top" id="mainNavbar">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <img src="@Url.Content("~/Content/imagenes/logo-jena.png")" alt="Jéna Training Methodology" class="navbar-logo" />
            </a>

            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarApex"
                    aria-controls="navbarApex" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarApex">
                <ul class="navbar-nav ms-auto align-items-center gap-2">

                    @if (User.IsInRole("ADMINISTRADOR"))
                    {
                        @* ── ADMINISTRADOR: sin Inicio ni Sobre Nosotros ── *@
                        <li class="nav-item">
                            @Html.ActionLink("Página de Inicio", "AdminIndex", "Home",
                                new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Página Nosotros", "Index", "SeccionesNosotros",
                                new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Usuarios", "Index", "Usuarios",
                                new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Entrenadores", "Administrar", "Entrenadores",
                                new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Clases", "ObtenerTodasLasClases", "Clases",
                                new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Reservas", "Administrar", "Reservas",
                                new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Bitácora", "Index", "Bitacoras",
                                new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Contacto", "Contact", "Home",
                                new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                    else
                    {
                        @* ── RESTO DE ROLES / PÚBLICO ── *@
                        <li class="nav-item">
                            @Html.ActionLink("Inicio", "Index", "Home", new { area = "" }, new { @class = "nav-link" })
                        </li>

                        if (Request.IsAuthenticated)
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Clases", "ObtenerTodasLasClases", "Clases", new { area = "" }, new { @class = "nav-link" })
                            </li>
                        }

                        if (User.IsInRole("ENTRENADOR"))
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Entrenador", "Index", "Entrenadores",
                                    new { area = "" }, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item">
                                @Html.ActionLink("Mis clases", "MisClases", "Entrenadores",
                                    new { area = "" }, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item">
                                @Html.ActionLink("Registrar asistencia", "MisClases", "Entrenadores",
                                    new { area = "" }, new { @class = "nav-link" })
                            </li>
                        }

                        if (User.IsInRole("CLIENTE"))
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Cliente", "MiPerfil", "Clientes",
                                    new { area = "" }, new { @class = "nav-link" })
                            </li>
                        }

                        <li class="nav-item">
                            @Html.ActionLink("Sobre Nosotros", "Index", "Nosotros", new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Contacto", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }

                    @* ── MEMBRESÍA SEGÚN ROL ── *@
                    @if (User.IsInRole("ADMINISTRADOR"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Membresía", "Index", "Membresias", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                    else if (User.IsInRole("CLIENTE"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Mi Membresía", "MiMembresia", "Clientes", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Membresía", "Planes", "Home", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }

                    @if (Request.IsAuthenticated)
                    {
                        var claimsIdentity = User.Identity as System.Security.Claims.ClaimsIdentity;
                        var nombreClaim = claimsIdentity != null ? claimsIdentity.FindFirst("NombreCompleto") : null;
                        var nombreMostrar = (nombreClaim != null && !string.IsNullOrEmpty(nombreClaim.Value))
                            ? nombreClaim.Value
                            : User.Identity.Name;
                        <li class="nav-item">
                            @Html.ActionLink("Hola, " + nombreMostrar, "Index", "Manage",
                                routeValues: null,
                                htmlAttributes: new { @class = "nav-link", style = "color: var(--jena-orange) !important;" })
                        </li>
                        <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                            @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm", @class = "d-inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-join-now">Cerrar sesión</button>
                            }
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Iniciar sesión", "Login", "Account",
                                routeValues: null,
                                htmlAttributes: new { @class = "nav-link" })
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a href="@Url.Action("Register", "Account")" class="btn btn-join-now">
                                Unirse Ahora
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer>
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-4">
                    <div class="footer-logo mb-3">Jéna Training Methodology</div>
                    <p class="mb-3" style="color: #ccc;">
                        Transforma tu cuerpo y tu mente. Únete a nosotros y alcanza tus metas fitness con el mejor equipo y entrenadores.
                    </p>
                    <div class="social-links">
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-4">
                    <h5>Enlaces Rápidos</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">@Html.ActionLink("Inicio", "Index", "Home")</li>
                        <li class="mb-2">@Html.ActionLink("Sobre Nosotros", "Index", "Nosotros")</li>
                        <li class="mb-2">@Html.ActionLink("Clases", "ObtenerTodasLasClases", "Clases")</li>
                        <li class="mb-2">@Html.ActionLink("Contacto", "Contact", "Home")</li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-4">
                    <h5>Servicios</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#">Entrenamiento Personal</a></li>
                        <li class="mb-2"><a href="#">Clases Grupales</a></li>
                        <li class="mb-2"><a href="#">Planes Nutricionales</a></li>
                        <li class="mb-2"><a href="#">Membresías</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-4">
                    <h5>Contacto</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="bi bi-geo-alt-fill me-2" style="color: var(--gym-accent);"></i>Calle Principal 123</li>
                        <li class="mb-2"><i class="bi bi-telephone-fill me-2" style="color: var(--gym-accent);"></i>+57 300 123 4567</li>
                        <li class="mb-2"><i class="bi bi-envelope-fill me-2" style="color: var(--gym-accent);"></i>info@gimnasiojena.com</li>
                        <li class="mb-2"><i class="bi bi-clock-fill me-2" style="color: var(--gym-accent);"></i>Lun-Sáb: 5AM - 10PM</li>
                    </ul>
                </div>
            </div>

            <div class="copyright text-center">
                <p class="mb-0">&copy; @DateTime.Now.Year Jéna Training Methodology. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)

    <script>
        (function () {
            var navbar = document.getElementById('mainNavbar');

            function onScroll() {
                if (window.scrollY > 50) {
                    navbar.classList.add('navbar-scrolled');
                } else {
                    navbar.classList.remove('navbar-scrolled');
                }
            }

            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
        })();
    </script>
</body>
</html>