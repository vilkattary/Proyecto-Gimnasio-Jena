@model GimnasioJena.Abstracciones.Modelos.Reservas.ReservaCrearDto

@{
    ViewBag.Title = "Reservar Clase";
}

<link href="@(Url.Content("~/Content/estilo/estilo.css"))" rel="stylesheet" />

<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="card shadow-sm rounded-4" style="border-top:4px solid var(--gym-orange);">
                <div class="card-body p-4">

                    <h2 class="fw-bold mb-3" style="color:var(--gym-dark);">
                        Reservar clase
                    </h2>

                    <p class="text-muted mb-4">
                        Confirma tu reserva para esta clase. El sistema registrará la reserva con tu usuario actual.
                    </p>

                    @if (TempData["MensajeError"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["MensajeError"]
                        </div>
                    }

                    @using (Html.BeginForm("ReservarClase", "Reservas", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        @Html.HiddenFor(m => m.idClaseProgramada)
                        @Html.HiddenFor(m => m.idEstadoReserva)

                        <div class="mb-3">
                            @Html.LabelFor(m => m.observaciones, "Observaciones", new { @class = "form-label fw-600" })
                            @Html.TextAreaFor(m => m.observaciones, new
                            {
                                @class = "form-control",
                                rows = "4",
                                placeholder = "Puedes agregar alguna observación opcional..."
                            })
                            @Html.ValidationMessageFor(m => m.observaciones, "", new { @class = "text-danger" })
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-action">
                                Confirmar reserva
                            </button>

                            <a href="@Url.Action("ObtenerTodasLasClases", "Clases")" class="btn btn-outline-gym">
                                Volver a clases
                            </a>
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}