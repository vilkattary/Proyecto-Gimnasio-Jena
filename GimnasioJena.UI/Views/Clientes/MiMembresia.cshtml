@{
    ViewBag.Title = "MiMembresia";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<style>
    /* ============================================
       SISTEMA DE DISEÑO - GIMNASIO JENA
       ============================================ */
    :root {
        /* Colores Core */
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;
        /* Colores de Acento */
        --jena-orange: #FF6B35;
        --jena-dark-orange: #D95F31;
        /* Colores de Soporte */
        --jena-light-blue: #6C8EA4;
        --jena-white: #FFFFFF;
        --jena-light-gray: #F8F9FA;
        /* Tipografía */
        --font-primary: 'Montserrat', sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background: linear-gradient(180deg, var(--jena-white) 0%, var(--jena-light-gray) 100%);
        color: var(--jena-navy);
        min-height: 100vh;
    }

    /* ============================================
       SECCIÓN DE BIENVENIDA CON LOGO
       ============================================ */
    .welcome-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding: 20px;
        background-color: var(--jena-white);
        border-radius: 20px;
        border: 2px solid var(--jena-light-blue);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .logo-circular {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background-color: var(--jena-orange);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        flex-shrink: 0;
    }

        .logo-circular i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            position: absolute;
        }

        .logo-circular .letter-j {
            font-size: 5rem;
            color: var(--jena-dark-navy);
            font-weight: 800;
            font-family: var(--font-primary);
            position: relative;
            z-index: 1;
        }

    .welcome-text h3 {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .welcome-text p {
        color: var(--jena-light-blue);
        font-weight: 400;
        margin: 0;
    }

    /* ============================================
       TÍTULO PRINCIPAL
       ============================================ */
    .page-title {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 8px;
        position: relative;
        display: inline-block;
        font-size: 2.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 5px;
            background-color: var(--jena-orange);
        }

    /* ============================================
       CARD DE MEMBRESÍA ACTUAL (DESTACADA)
       ============================================ */
    .current-membership-card {
        background: linear-gradient(135deg, var(--jena-navy) 0%, var(--jena-dark-navy) 100%);
        border: 3px solid var(--jena-orange);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 40px rgba(255, 107, 53, 0.3);
        position: relative;
        overflow: hidden;
        margin-bottom: 40px;
    }

        .current-membership-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 107, 53, 0.1) 0%, transparent 70%);
            animation: pulse 3s ease-in-out infinite;
        }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
            opacity: 0.5;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.8;
        }
    }

    .current-membership-card .badge-active {
        background-color: var(--jena-orange);
        color: var(--jena-white);
        font-size: 0.85rem;
        font-weight: 800;
        padding: 8px 20px;
        border-radius: 50px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
        margin-bottom: 20px;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.4);
    }

    .current-membership-card h2 {
        color: var(--jena-white);
        font-weight: 800;
        font-size: 2.5rem;
        margin-bottom: 15px;
        position: relative;
        z-index: 1;
    }

    .current-membership-card .membership-description {
        color: var(--jena-white);
        font-size: 1.1rem;
        line-height: 1.8;
        margin-bottom: 20px;
        opacity: 0.9;
        position: relative;
        z-index: 1;
    }

    .current-membership-card .membership-features {
        list-style: none;
        padding: 0;
        margin-bottom: 25px;
        position: relative;
        z-index: 1;
    }

        .current-membership-card .membership-features li {
            color: var(--jena-white);
            padding: 10px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .current-membership-card .membership-features li:last-child {
                border-bottom: none;
            }

            .current-membership-card .membership-features li i {
                color: var(--jena-orange);
                font-size: 1.3rem;
            }

    .current-membership-card .renewal-info {
        background-color: rgba(255, 255, 255, 0.1);
        border-left: 4px solid var(--jena-orange);
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 25px;
        position: relative;
        z-index: 1;
    }

        .current-membership-card .renewal-info p {
            color: var(--jena-white);
            margin: 0;
            font-weight: 600;
        }

            .current-membership-card .renewal-info p small {
                color: rgba(255, 255, 255, 0.7);
                display: block;
                margin-top: 5px;
                font-weight: 400;
            }

    .current-membership-card .price {
        color: var(--jena-orange);
        font-size: 3rem;
        font-weight: 800;
        position: relative;
        z-index: 1;
    }

        .current-membership-card .price span {
            font-size: 1.2rem;
            color: var(--jena-white);
            opacity: 0.8;
        }

    /* ============================================
       CARDS DE OTROS PLANES
       ============================================ */
    .plan-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .plan-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 0;
            background-color: var(--jena-orange);
            transition: height 0.3s ease;
        }

        .plan-card:hover {
            border-color: var(--jena-orange);
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.25);
        }

            .plan-card:hover::before {
                height: 5px;
            }

        .plan-card .plan-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--jena-orange) 0%, var(--jena-dark-orange) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            box-shadow: 0 5px 15px rgba(255, 107, 53, 0.3);
        }

            .plan-card .plan-icon i {
                font-size: 2.5rem;
                color: var(--jena-white);
            }

        .plan-card h4 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 1.8rem;
            text-align: center;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .plan-card .plan-subtitle {
            color: var(--jena-light-blue);
            text-align: center;
            font-weight: 600;
            font-size: 0.95rem;
            margin-bottom: 20px;
        }

        .plan-card .plan-features {
            list-style: none;
            padding: 0;
            margin-bottom: 25px;
            flex-grow: 1;
        }

            .plan-card .plan-features li {
                color: var(--jena-navy);
                padding: 10px 0;
                border-bottom: 1px solid var(--jena-light-gray);
                display: flex;
                align-items: center;
                gap: 10px;
                font-weight: 500;
            }

                .plan-card .plan-features li:last-child {
                    border-bottom: none;
                }

                .plan-card .plan-features li i {
                    color: var(--jena-orange);
                    font-size: 1.1rem;
                    flex-shrink: 0;
                }

        .plan-card .price {
            text-align: center;
            color: var(--jena-orange);
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 20px;
        }

            .plan-card .price span {
                font-size: 1rem;
                color: var(--jena-light-blue);
                font-weight: 600;
            }

    /* ============================================
       BOTONES
       ============================================ */
    .btn-orange {
        background-color: var(--jena-orange);
        color: var(--jena-white);
        border: none;
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
        width: 100%;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

        .btn-orange:hover {
            background-color: var(--jena-dark-orange);
            color: var(--jena-white);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

    .btn-outline {
        background-color: var(--jena-white);
        color: var(--jena-navy);
        border: 2px solid var(--jena-orange);
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.15);
        width: 100%;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

        .btn-outline:hover {
            background-color: var(--jena-orange);
            color: var(--jena-white);
            border-color: var(--jena-orange);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

    /* ============================================
       SECCIÓN DE TÍTULO
       ============================================ */
    .section-header {
        text-align: center;
        margin-bottom: 50px;
    }

        .section-header .section-subtitle {
            color: var(--jena-orange);
            font-weight: 700;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 10px;
        }

        .section-header h2 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 15px;
            position: relative;
            display: inline-block;
        }

            .section-header h2::after {
                content: '';
                position: absolute;
                bottom: -10px;
                left: 50%;
                transform: translateX(-50%);
                width: 80px;
                height: 5px;
                background-color: var(--jena-orange);
            }

    /* ============================================
       RESPONSIVE (MÓVILES < 768px)
       ============================================ */
    @@media (max-width: 768px) {
        .logo-circular {
            width: 120px;
            height: 120px;
        }

            .logo-circular i {
                font-size: 3rem;
            }

            .logo-circular .letter-j {
                font-size: 4rem;
            }

        .welcome-section {
            flex-direction: column;
            text-align: center;
            padding: 15px;
        }

        .page-title {
            font-size: 1.8rem;
            text-align: center;
            display: block;
        }

        .current-membership-card {
            padding: 25px;
        }

            .current-membership-card h2 {
                font-size: 2rem;
            }

            .current-membership-card .price {
                font-size: 2.5rem;
            }

        .plan-card {
            margin-bottom: 1.5rem;
        }

        .section-header h2 {
            font-size: 1.8rem;
        }
    }
</style>

<div class="container-fluid p-4">
    <!-- Sección de Bienvenida con Logo -->
    <div class="welcome-section">
        <div class="logo-circular">
            <i class="bi bi-tree"></i>
            <span class="letter-j">J</span>
        </div>
        <div class="welcome-text">
            <h3>Gestión de Membresías</h3>
            <p>Administra tu plan actual y explora nuevas opciones</p>
        </div>
    </div>

    <!-- Título Principal -->
    <div class="text-center mb-5">
        <h2 class="page-title">Mi Membresía</h2>
    </div>

    <!-- Card de Membresía Actual -->
    <div class="current-membership-card">
        <div class="text-center">
            <span class="badge-active">
                <i class="bi bi-check-circle-fill me-2"></i>Membresía Activa
            </span>
        </div>

        <div class="row align-items-center">
            <div class="col-lg-8">
                <h2>Plan Estándar</h2>
                <p class="membership-description">
                    Para quienes entrenan con frecuencia. Disfruta de acceso completo a todas las instalaciones
                    y beneficios exclusivos para miembros regulares.
                </p>

                <ul class="membership-features">
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Acceso completo al gimnasio</span>
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Clases grupales ilimitadas</span>
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>1 sesión mensual con entrenador personal</span>
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Acceso a vestidores y duchas</span>
                    </li>
                </ul>

                <div class="renewal-info">
                    <p>
                        <i class="bi bi-calendar-event me-2"></i>
                        <strong>Próxima renovación:</strong> 6 de Mayo, 2026
                        <small>Tu membresía se renovará automáticamente</small>
                    </p>
                </div>
            </div>

            <div class="col-lg-4 text-center">
                <div class="price">
                    $39<span> / mes</span>
                </div>
                <a href="#" class="btn btn-outline mb-3">
                    <i class="bi bi-arrow-repeat me-2"></i>Renovar Ahora
                </a>
                <a href="#" class="btn btn-outline">
                    <i class="bi bi-gear me-2"></i>Gestionar Plan
                </a>
            </div>
        </div>
    </div>

    <!-- Sección de Otros Planes -->
    <div class="section-header">
        <p class="section-subtitle">Opciones Disponibles</p>
        <h2>Explora Otros Planes</h2>
    </div>

    <div class="row mb-5">
        <!-- Plan Básico -->
        <div class="col-lg-4 mb-4">
            <div class="plan-card">
                <div class="plan-icon">
                    <i class="bi bi-heart"></i>
                </div>
                <h4>Plan Básico</h4>
                <p class="plan-subtitle">Ideal para comenzar</p>

                <ul class="plan-features">
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Acceso a gimnasio en horario limitado</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Máquinas básicas disponibles</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>1 clase grupal a la semana</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Acceso a vestidores</span>
                    </li>
                </ul>

                <div class="price">
                    $19<span> / mes</span>
                </div>

                <a href="#" class="btn btn-outline">
                    <i class="bi bi-info-circle me-2"></i>Ver Detalles
                </a>
            </div>
        </div>

        <!-- Plan Premium -->
        <div class="col-lg-4 mb-4">
            <div class="plan-card">
                <div class="plan-icon">
                    <i class="bi bi-star-fill"></i>
                </div>
                <h4>Plan Premium</h4>
                <p class="plan-subtitle">Máxima experiencia y beneficios</p>

                <ul class="plan-features">
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Acceso VIP 24/7 sin restricciones</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Entrenador personal semanal</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Descuentos en suplementos y tienda</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Acceso prioritario a clases exclusivas</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Toalla y casillero premium incluido</span>
                    </li>
                </ul>

                <div class="price">
                    $69<span> / mes</span>
                </div>

                <a href="#" class="btn btn-outline">
                    <i class="bi bi-arrow-up-circle me-2"></i>Mejorar Plan
                </a>
            </div>
        </div>

        <!-- Plan Anual -->
        <div class="col-lg-4 mb-4">
            <div class="plan-card">
                <div class="plan-icon">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <h4>Plan Anual</h4>
                <p class="plan-subtitle">Ahorro del 15% + regalo</p>

                <ul class="plan-features">
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Todos los beneficios del Plan Estándar</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Ahorro de $220 al año</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Regalo de bienvenida exclusivo</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Pago único sin renovaciones mensuales</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Prioridad en reservas de clases</span>
                    </li>
                </ul>

                <div class="price">
                    $688<span> / año</span>
                </div>

                <a href="#" class="btn btn-outline">
                    <i class="bi bi-calculator me-2"></i>Ver Ahorro
                </a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>