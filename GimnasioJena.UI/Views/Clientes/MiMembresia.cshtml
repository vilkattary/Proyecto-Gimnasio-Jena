@model GimnasioJena.Abstracciones.Modelos.Usuarios.UsuarioPerfilDto
@{
    ViewBag.Title = "MiMembresia";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<link href="@(Url.Content("~/Content/estilo/estilo.css"))" rel="stylesheet" />

<div class="container-fluid p-4">
    <!-- Sección de Bienvenida con Logo -->
    <div class="welcome-section">
        <div class="logo-circular">
            <i class="bi bi-tree"></i>
            <span class="letter-j">J</span>
        </div>
        <div class="welcome-text">
            <h3>Gestión de Membresías</h3>
            <p>Administra tu plan actual y explora nuevas opciones</p>
        </div>
    </div>

    <!-- Título Principal -->
    <div class="text-center mb-5">
        <h2 class="page-title">Mi Membresía</h2>
    </div>

    <!-- Card de Membresía Actual -->
    <div class="current-membership-card">
        <h5 class="text-center mb-3" style="color: var(--jena-navy); font-weight: 800;">
            <i class="bi bi-star-fill" style="color: var(--jena-orange);"></i>
            @if (Model.Membresia.estadoMembresia == "Activa")
            {
                @:Membresía Activa
            }
            else
            {
                @:Membresía Inactiva
            }
        </h5>

        <div class="row align-items-center">
            <div class="col-lg-8">
                <h2 class="info-value">@Model.Membresia.nombrePlan</h2>
                <p class="membership-description">
                    Para quienes entrenan con frecuencia. Disfruta de acceso completo a todas las instalaciones
                    y beneficios exclusivos para miembros regulares.
                </p>

                <ul class="membership-features">
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Acceso completo al gimnasio</span>
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Clases grupales ilimitadas</span>
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>1 sesión mensual con entrenador personal</span>
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Acceso a vestidores y duchas</span>
                    </li>
                </ul>

                <div class="renewal-info">
                    <p>
                        <i class="bi bi-calendar-event me-2"></i>
                        <strong>Próxima renovación:</strong> <h2 class="info-value">@Model.Membresia.fechaFin</h2>
                        <small>Tu membresía se renovará automáticamente</small>
                    </p>
                </div>
            </div>

            <div class="col-lg-4 text-center">
                <div class="price">
                    <h2 class="info-value">@Model.Membresia.precio</h2> <span> / mes</span>
                </div>
                <a href="#" class="btn btn-outline mb-3">
                    <i class="bi bi-arrow-repeat me-2"></i>Renovar Ahora
                </a>
                <a href="#" class="btn btn-outline">
                    <i class="bi bi-gear me-2"></i>Gestionar Plan
                </a>
            </div>
        </div>
    </div>

    <!-- Sección de Otros Planes -->
    <div class="section-header">
        <p class="section-subtitle">Opciones Disponibles</p>
        <h2>Explora Otros Planes</h2>
    </div>

    <div class="row mb-5">
        <!-- Plan Básico -->
        <div class="col-lg-4 mb-4">
            <div class="plan-card">
                <div class="plan-icon">
                    <i class="bi bi-heart"></i>
                </div>
                <h4>Plan Básico</h4>
                <p class="plan-subtitle">Ideal para comenzar</p>

                <ul class="plan-features">
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Acceso a gimnasio en horario limitado</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Máquinas básicas disponibles</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>1 clase grupal a la semana</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Acceso a vestidores</span>
                    </li>
                </ul>

                <div class="price">
                    $19<span> / mes</span>
                </div>

                <a href="#" class="btn btn-outline">
                    <i class="bi bi-info-circle me-2"></i>Ver Detalles
                </a>
            </div>
        </div>

        <!-- Plan Premium -->
        <div class="col-lg-4 mb-4">
            <div class="plan-card">
                <div class="plan-icon">
                    <i class="bi bi-star-fill"></i>
                </div>
                <h4>Plan Premium</h4>
                <p class="plan-subtitle">Máxima experiencia y beneficios</p>

                <ul class="plan-features">
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Acceso VIP 24/7 sin restricciones</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Entrenador personal semanal</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Descuentos en suplementos y tienda</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Acceso prioritario a clases exclusivas</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Toalla y casillero premium incluido</span>
                    </li>
                </ul>

                <div class="price">
                    $69<span> / mes</span>
                </div>

                <a href="#" class="btn btn-outline">
                    <i class="bi bi-arrow-up-circle me-2"></i>Mejorar Plan
                </a>
            </div>
        </div>

        <!-- Plan Anual -->
        <div class="col-lg-4 mb-4">
            <div class="plan-card">
                <div class="plan-icon">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <h4>Plan Anual</h4>
                <p class="plan-subtitle">Ahorro del 15% + regalo</p>

                <ul class="plan-features">
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Todos los beneficios del Plan Estándar</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Ahorro de $220 al año</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Regalo de bienvenida exclusivo</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Pago único sin renovaciones mensuales</span>
                    </li>
                    <li>
                        <i class="bi bi-check-lg"></i>
                        <span>Prioridad en reservas de clases</span>
                    </li>
                </ul>

                <div class="price">
                    $688<span> / año</span>
                </div>

                <a href="#" class="btn btn-outline">
                    <i class="bi bi-calculator me-2"></i>Ver Ahorro
                </a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>