@model GimnasioJena.Abstracciones.Modelos.Usuarios.UsuarioPerfilDto

@{
    ViewBag.Title = "MiPerfil";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link href="@(Url.Content("~/Content/estilo/estilo.css"))" rel="stylesheet" />

<div class="container-fluid p-4">

    <div class="welcome-section">
        @if (!string.IsNullOrWhiteSpace(Model.fotoPerfil))
        {
            <img src="@Url.Content(Model.fotoPerfil)"
                 class="rounded-circle"
                 style="width:90px;height:90px;object-fit:cover;border:3px solid var(--jena-orange);" />
        }
        else
        {
            <div class="logo-circular">
                <i class="bi bi-tree"></i>
                <span class="initials">
                    @Model.nombre.Substring(0, 1)@Model.apellido1.Substring(0, 1)
                </span>
            </div>
        }

        <div class="welcome-text">
            <h3>Mi Perfil Personal</h3>
            <div class="info-value">@Model.nombre @Model.apellido1 @Model.apellido2</div>
            <p>Gestiona tu información y preferencias del gimnasio</p>
        </div>
    </div>

    <div class="text-center mb-5">
        <h2 class="page-title">Mi Perfil</h2>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <i class="bi bi-calendar-check"></i>
            <h3>15</h3>
            <p>Clases Tomadas</p>
        </div>

        <div class="stat-card">
            <i class="bi bi-trophy"></i>
            <h3>3</h3>
            <p>Logros</p>
        </div>

        <div class="stat-card">
            <i class="bi bi-star-fill"></i>
            <h3>Gold</h3>
            <p>Membresía</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="info-card">
                <div class="row">
                    <div class="col-md-4 profile-section mb-3 mb-md-0">
                        @if (!string.IsNullOrWhiteSpace(Model.fotoPerfil))
                        {
                            <img src="@Url.Content(Model.fotoPerfil)"
                                 class="profile-avatar mx-auto"
                                 style="object-fit:cover;" />
                        }
                        else
                        {
                            <div class="profile-avatar mx-auto">
                                <span class="initials">
                                    @Model.nombre.Substring(0, 1)@Model.apellido1.Substring(0, 1)
                                </span>
                                <div class="verified-badge">
                                    <i class="bi bi-check-lg"></i>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="col-md-8">
                        <div class="info-item">
                            <i class="bi bi-person-circle"></i>
                            <div class="info-content">
                                <div class="info-label">Nombre Completo</div>
                                <div class="info-value">@Model.nombre @Model.apellido1 @Model.apellido2</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-envelope"></i>
                            <div class="info-content">
                                <div class="info-label">Correo Electrónico</div>
                                <div class="info-value">@Model.correo</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-telephone"></i>
                            <div class="info-content">
                                <div class="info-label">Teléfono</div>
                                <div class="info-value">@Model.telefono</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-geo-alt"></i>
                            <div class="info-content">
                                <div class="info-label">Dirección</div>
                                <div class="info-value">
                                    @(string.IsNullOrWhiteSpace(Model.direccion) ? "Sin dirección registrada" : Model.direccion)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="description-card">
                <h5><i class="bi bi-info-circle me-2"></i>Sobre Mí</h5>
                <p>
                    Apasionado por el fitness y el bienestar. Disfruto ayudando a otros a alcanzar sus metas.
                    Me especializo en entrenamiento de fuerza y resistencia. Creo firmemente que la constancia
                    y la disciplina son las claves del éxito en cualquier objetivo físico.
                </p>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="action-buttons-card">
                <h5><i class="bi bi-lightning-charge me-2"></i>Acciones Rápidas</h5>

                <a href="@Url.Action("MiMembresia", "Clientes")" class="btn btn-action">
                    <i class="bi bi-credit-card"></i>
                    <span>Mi Membresía</span>
                </a>

                <a href="@Url.Action("ReservarClases", "Clientes")" class="btn btn-action">
                    <i class="bi bi-calendar-plus"></i>
                    <span>Reservar Clase</span>
                </a>

                <a href="@Url.Action("MisReservas", "Clientes")" class="btn btn-action">
                    <i class="bi bi-list-check"></i>
                    <span>Mis Reservas</span>
                </a>

                <a href="@Url.Action("EditarPerfil", "Manage")" class="btn btn-action">
                    <i class="bi bi-pencil-square"></i>
                    <span>Editar Perfil</span>
                </a>
            </div>

            <div class="info-card">
                <h5 class="text-center mb-3" style="color: var(--jena-navy); font-weight: 800;">
                    <i class="bi bi-star-fill" style="color: var(--jena-orange);"></i>
                    Membresía Activa
                </h5>

                @if (Model.Membresia != null)
                {
                    <div class="text-center">
                        <div class="mb-3">
                            <span style="font-size: 2rem; font-weight: 800; color: var(--jena-orange);">
                                @Model.Membresia.nombrePlan
                            </span>
                        </div>

                        <div class="info-item justify-content-center" style="border: none; padding: 0;">
                            <i class="bi bi-calendar-event"></i>
                            <div class="info-content" style="text-align: center;">
                                <div class="info-label">Estado</div>
                                <div class="info-value">@Model.Membresia.estadoMembresia</div>
                            </div>
                        </div>

                        <div class="info-item justify-content-center" style="border: none; padding: 0;">
                            <i class="bi bi-calendar-check"></i>
                            <div class="info-content" style="text-align: center;">
                                <div class="info-label">Válida Hasta</div>
                                <div class="info-value">@Model.Membresia.fechaFin.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>

                        @if (Model.Membresia.clasesDisponibles.HasValue)
                        {
                            <div class="info-item justify-content-center" style="border: none; padding: 0;">
                                <i class="bi bi-activity"></i>
                                <div class="info-content" style="text-align: center;">
                                    <div class="info-label">Clases Disponibles</div>
                                    <div class="info-value">@Model.Membresia.clasesDisponibles</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center">
                        <i class="bi bi-x-circle" style="font-size: 2rem; color: #ccc;"></i>
                        <p class="mt-2" style="color: #999;">No tienes una membresía activa.</p>

                        <a href="@Url.Action("Planes", "Home")" class="btn btn-action mt-2">
                            <i class="bi bi-plus-circle"></i>
                            <span>Ver Planes</span>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>