@model GimnasioJena.Abstracciones.Modelos.Reservas.ReservaListadoDto

@{
    ViewBag.Title = "Detalle de Reserva";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="page-title">Detalle de Reserva</h1>
        <p class="text-muted">Información completa de tu reserva.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="info-card">

                <h4 class="mb-4" style="color:var(--jena-navy);">
                    <i class="bi bi-calendar-check me-2" style="color:var(--jena-orange);"></i>
                    @Model.nombreClase
                </h4>

                <p><strong>Cliente:</strong> @Model.nombreCliente</p>
                <p><strong>Entrenador:</strong> @Model.nombreEntrenador</p>
                <p><strong>Estado:</strong> @Model.estadoReserva</p>
                <p><strong>Fecha de la clase:</strong> @Model.fechaClase.ToString("dd/MM/yyyy")</p>
                <p><strong>Horario:</strong> @Model.horaInicio.ToString(@"hh\:mm") - @Model.horaFin.ToString(@"hh\:mm")</p>
                <p><strong>Ubicación:</strong> @Model.ubicacion</p>
                <p><strong>Fecha de reserva:</strong> @Model.fechaReserva.ToString("dd/MM/yyyy HH:mm")</p>

                <div class="mt-4 d-flex gap-2 flex-wrap">
                    <a href="@Url.Action("MisReservas", "Clientes")" class="btn btn-outline-gym">
                        Volver a Mis Reservas
                    </a>

                    @if (Model.idEstadoReserva == 1)
                    {
                        using (Html.BeginForm("CancelarReserva", "Clientes", FormMethod.Post, new { @class = "d-inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.idReserva" />

                            <button type="submit"
                                    class="btn btn-danger"
                                    onclick="return confirm('¿Estás seguro de cancelar esta reserva?')">
                                Cancelar Reserva
                            </button>
                        }
                    }
                </div>

            </div>
        </div>
    </div>
</div>