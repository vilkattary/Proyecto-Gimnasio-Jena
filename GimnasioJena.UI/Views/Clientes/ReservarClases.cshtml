@{
    ViewBag.Title = "ReservarClases";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<style>
    /* ============================================
       SISTEMA DE DISEÑO - GIMNASIO JENA
       ============================================ */
    :root {
        /* Colores Core */
        --jena-navy: #2C3E50;
        --jena-dark-navy: #1A2332;
        /* Colores de Acento */
        --jena-orange: #FF6B35;
        --jena-dark-orange: #D95F31;
        /* Colores de Soporte */
        --jena-light-blue: #6C8EA4;
        --jena-white: #FFFFFF;
        --jena-light-gray: #F8F9FA;
        /* Tipografía */
        --font-primary: 'Montserrat', sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background: linear-gradient(180deg, var(--jena-white) 0%, var(--jena-light-gray) 100%);
        color: var(--jena-navy);
        min-height: 100vh;
    }

    /* ============================================
       SECCIÓN DE BIENVENIDA CON LOGO
       ============================================ */
    .welcome-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding: 20px;
        background-color: var(--jena-white);
        border-radius: 20px;
        border: 2px solid var(--jena-light-blue);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .logo-circular {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background-color: var(--jena-orange);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        flex-shrink: 0;
    }

        .logo-circular i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            position: absolute;
        }

        .logo-circular .letter-j {
            font-size: 5rem;
            color: var(--jena-dark-navy);
            font-weight: 800;
            font-family: var(--font-primary);
            position: relative;
            z-index: 1;
        }

    .welcome-text h3 {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .welcome-text p {
        color: var(--jena-light-blue);
        font-weight: 400;
        margin: 0;
    }

    /* ============================================
       TÍTULO PRINCIPAL
       ============================================ */
    .page-title {
        color: var(--jena-navy);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 8px;
        position: relative;
        display: inline-block;
        font-size: 2.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 5px;
            background-color: var(--jena-orange);
        }

    /* ============================================
       FILTROS
       ============================================ */
    .filter-section {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

        .filter-section .filter-label {
            color: var(--jena-navy);
            font-weight: 700;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
            display: block;
        }

        .filter-section .form-select {
            border: 2px solid var(--jena-light-blue);
            border-radius: 12px;
            padding: 12px 15px;
            font-weight: 500;
            color: var(--jena-navy);
            background-color: var(--jena-white);
            transition: all 0.3s ease;
        }

            .filter-section .form-select:focus {
                border-color: var(--jena-orange);
                box-shadow: 0 0 0 0.25rem rgba(255, 107, 53, 0.15);
                outline: none;
            }

    /* ============================================
       CARDS DE CLASES
       ============================================ */
    .class-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        position: relative;
        margin-bottom: 25px;
    }

        .class-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 0;
            background-color: var(--jena-orange);
            transition: height 0.3s ease;
            z-index: 1;
        }

        .class-card:hover {
            border-color: var(--jena-orange);
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.25);
        }

            .class-card:hover::before {
                height: 5px;
            }

    /* ============================================
       PLACEHOLDER DE IMAGEN (SIN IMÁGENES EXTERNAS)
       ============================================ */
    .class-image-placeholder {
        width: 100%;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .class-image-placeholder.spinning {
            background: linear-gradient(135deg, var(--jena-orange) 0%, var(--jena-dark-orange) 100%);
        }

        .class-image-placeholder.yoga {
            background: linear-gradient(135deg, var(--jena-light-blue) 0%, var(--jena-navy) 100%);
        }

        .class-image-placeholder.boxing {
            background: linear-gradient(135deg, var(--jena-dark-navy) 0%, var(--jena-navy) 100%);
        }

        .class-image-placeholder.crossfit {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }

        .class-image-placeholder.hiit {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        }

        .class-image-placeholder i {
            font-size: 5rem;
            color: rgba(255, 255, 255, 0.9);
            z-index: 1;
        }

        .class-image-placeholder::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: var(--jena-orange);
        }

    /* ============================================
       CONTENIDO DE LA CARD
       ============================================ */
    .class-card-body {
        padding: 25px;
    }

        .class-card-body .badge-membership {
            background-color: rgba(255, 107, 53, 0.15);
            color: var(--jena-orange);
            font-size: 0.75rem;
            font-weight: 800;
            padding: 6px 15px;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
            margin-bottom: 15px;
            border: 2px solid var(--jena-orange);
        }

        .class-card-body .badge-available {
            background-color: rgba(40, 167, 69, 0.15);
            color: #28a745;
            font-size: 0.75rem;
            font-weight: 800;
            padding: 6px 15px;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
            margin-bottom: 15px;
            border: 2px solid #28a745;
            margin-left: 10px;
        }

        .class-card-body h4 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 1.8rem;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .class-card-body .class-info {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
            color: var(--jena-navy);
            font-weight: 500;
        }

            .class-card-body .class-info i {
                color: var(--jena-orange);
                font-size: 1.3rem;
                margin-right: 12px;
                width: 25px;
            }

            .class-card-body .class-info strong {
                color: var(--jena-navy);
                margin-left: 5px;
                font-weight: 700;
            }

    /* ============================================
       BOTONES
       ============================================ */
    .btn-reserve {
        background-color: var(--jena-orange);
        color: var(--jena-white);
        border: none;
        border-radius: 50px;
        padding: 14px 35px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-reserve:hover {
            background-color: var(--jena-dark-orange);
            color: var(--jena-white);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

        .btn-reserve i {
            font-size: 1.2rem;
        }

    .btn-filter {
        background-color: var(--jena-orange);
        color: var(--jena-white);
        border: none;
        border-radius: 50px;
        padding: 12px 25px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
    }

        .btn-filter:hover {
            background-color: var(--jena-dark-orange);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }
    
    /* ============================================
BOTONES DE ACCIÓN
============================================ */
    .action-buttons-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        margin-bottom: 30px;
    }

        .action-buttons-card h5 {
            color: var(--jena-navy);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            text-align: center;
            position: relative;
            padding-bottom: 12px;
        }

            .action-buttons-card h5::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 3px;
                background-color: var(--jena-orange);
            }

    .btn-action {
        background-color: var(--jena-white);
        color: var(--jena-navy);
        border: 2px solid var(--jena-orange);
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.15);
        width: 100%;
        margin-bottom: 15px;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-action:last-child {
            margin-bottom: 0;
        }

        .btn-action:hover {
            background-color: var(--jena-orange);
            color: var(--jena-white);
            border-color: var(--jena-orange);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

        .btn-action:active {
            transform: translateY(-1px);
        }

        .btn-action i {
            font-size: 1.2rem;
            color: var(--jena-orange);
            transition: color 0.3s ease;
        }

        .btn-action:hover i {
            color: var(--jena-white);
        }


    /* ============================================
       ESTADÍSTICAS
       ============================================ */
    .stats-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background-color: var(--jena-white);
        border: 2px solid var(--jena-light-blue);
        border-radius: 20px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

        .stat-card:hover {
            border-color: var(--jena-orange);
            transform: translateY(-5px);
        }

        .stat-card i {
            font-size: 2.5rem;
            color: var(--jena-orange);
            margin-bottom: 10px;
        }

        .stat-card h3 {
            color: var(--jena-navy);
            font-weight: 800;
            font-size: 2rem;
            margin-bottom: 5px;
        }

        .stat-card p {
            color: var(--jena-light-blue);
            font-weight: 600;
            font-size: 0.85rem;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    /* ============================================
       RESPONSIVE (MÓVILES < 768px)
       ============================================ */
    @@media (max-width: 768px) {
        .logo-circular {
            width: 120px;
            height: 120px;
        }

            .logo-circular i {
                font-size: 3rem;
            }

            .logo-circular .letter-j {
                font-size: 4rem;
            }

        .welcome-section {
            flex-direction: column;
            text-align: center;
            padding: 15px;
        }

        .page-title {
            font-size: 1.8rem;
            text-align: center;
            display: block;
        }

        .filter-section {
            padding: 20px;
        }

        .class-image-placeholder {
            height: 150px;
        }

            .class-image-placeholder i {
                font-size: 3.5rem;
            }

        .class-card-body {
            padding: 20px;
        }

            .class-card-body h4 {
                font-size: 1.4rem;
            }

        .btn-reserve {
            width: 100%;
            justify-content: center;
        }

        .class-card {
            margin-bottom: 1.5rem;
        }
    }
</style>

<div class="container-fluid p-4">
    <!-- Sección de Bienvenida con Logo -->
    <div class="welcome-section">
        <div class="logo-circular">
            <i class="bi bi-tree"></i>
            <span class="letter-j">J</span>
        </div>
        <div class="welcome-text">
            <h3>Reserva de Clases</h3>
            <p>Encuentra y reserva las mejores clases para tu entrenamiento</p>
        </div>
    </div>

    <!-- Título Principal -->
    <div class="text-center mb-5">
        <h2 class="page-title">Clases Disponibles</h2>
    </div>

    <!-- Estadísticas Rápidas -->
    <div class="stats-section">
        <div class="stat-card">
            <i class="bi bi-calendar-check"></i>
            <h3>12</h3>
            <p>Clases Hoy</p>
        </div>
        <div class="stat-card">
            <i class="bi bi-people"></i>
            <h3>85</h3>
            <p>Plazas Libres</p>
        </div>
        <div class="stat-card">
            <i class="bi bi-star-fill"></i>
            <h3>5</h3>
            <p>Instructores</p>
        </div>
    </div>

    <!-- Filtros -->
    <div class="filter-section">
        <div class="row align-items-end">
            <div class="col-md-4 mb-3 mb-md-0">
                <label class="filter-label">
                    <i class="bi bi-funnel me-2"></i>Tipo de Clase
                </label>
                <select class="form-select">
                    <option value="">Todas las clases</option>
                    <option value="spinning">Spinning</option>
                    <option value="yoga">Yoga</option>
                    <option value="boxing">Boxing</option>
                    <option value="crossfit">CrossFit</option>
                    <option value="hiit">HIIT</option>
                </select>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
                <label class="filter-label">
                    <i class="bi bi-sort-down me-2"></i>Ordenar Por
                </label>
                <select class="form-select">
                    <option value="">Seleccionar</option>
                    <option value="date">Fecha</option>
                    <option value="time">Hora</option>
                    <option value="instructor">Instructor</option>
                    <option value="available">Disponibilidad</option>
                </select>
            </div>
            <div class="col-md-4">
                <button class="btn btn-action w-100">
                    <i class="bi bi-search me-2"></i>Buscar
                </button>
            </div>
        </div>
    </div>

    <!-- Lista de Clases -->
    <div class="row">
        <!-- Clase 1: Spinning -->
        <div class="col-12">
            <div class="class-card">
                <div class="row g-0">
                    <div class="col-md-3">
                        <div class="class-image-placeholder spinning">
                            <i class="bi bi-bicycle"></i>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="class-card-body">
                            <div>
                                <span class="badge-membership">
                                    <i class="bi bi-star-fill me-1"></i>Mi Membresía
                                </span>
                                <span class="badge-available">
                                    <i class="bi bi-check-circle me-1"></i>15 Plazas
                                </span>
                            </div>
                            <h4>Clases de Spinning</h4>

                            <div class="class-info">
                                <i class="bi bi-person-badge"></i>
                                <span>Instructor: <strong>Diego Pérez</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-clock"></i>
                                <span>Hora: <strong>10:00 AM - 11:00 AM</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-calendar-event"></i>
                                <span>Fecha: <strong>30/05/2026</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-geo-alt"></i>
                                <span>Sala: <strong>Studio A</strong></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-center justify-content-center p-3">
                        <a href="#" class="btn btn-action">
                            <i class="bi bi-bookmark-plus"></i>
                            <span>Reservar</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Clase 2: Yoga -->
        <div class="col-12">
            <div class="class-card">
                <div class="row g-0">
                    <div class="col-md-3">
                        <div class="class-image-placeholder yoga">
                            <i class="bi bi-heart-pulse"></i>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="class-card-body">
                            <div>
                                <span class="badge-available">
                                    <i class="bi bi-check-circle me-1"></i>8 Plazas
                                </span>
                            </div>
                            <h4>Clases de Yoga</h4>

                            <div class="class-info">
                                <i class="bi bi-person-badge"></i>
                                <span>Instructor: <strong>María Gómez</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-clock"></i>
                                <span>Hora: <strong>5:00 PM - 6:00 PM</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-calendar-event"></i>
                                <span>Fecha: <strong>29/05/2026</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-geo-alt"></i>
                                <span>Sala: <strong>Studio Zen</strong></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-center justify-content-center p-3">
                        <a href="#" class="btn btn-action">
                            <i class="bi bi-bookmark-plus"></i>
                            <span>Reservar</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Clase 3: Boxeo -->
        <div class="col-12">
            <div class="class-card">
                <div class="row g-0">
                    <div class="col-md-3">
                        <div class="class-image-placeholder boxing">
                            <i class="bi bi-trophy"></i>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="class-card-body">
                            <div>
                                <span class="badge-available">
                                    <i class="bi bi-check-circle me-1"></i>10 Plazas
                                </span>
                            </div>
                            <h4>Clases de Boxeo</h4>

                            <div class="class-info">
                                <i class="bi bi-person-badge"></i>
                                <span>Instructor: <strong>Carlos Ramírez</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-clock"></i>
                                <span>Hora: <strong>7:00 PM - 8:30 PM</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-calendar-event"></i>
                                <span>Fecha: <strong>28/05/2026</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-geo-alt"></i>
                                <span>Sala: <strong>Ring Principal</strong></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-center justify-content-center p-3">
                        <a href="#" class="btn btn-action">
                            <i class="bi bi-bookmark-plus"></i>
                            <span>Reservar</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Clase 4: CrossFit -->
        <div class="col-12">
            <div class="class-card">
                <div class="row g-0">
                    <div class="col-md-3">
                        <div class="class-image-placeholder crossfit">
                            <i class="bi bi-lightning-charge"></i>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="class-card-body">
                            <div>
                                <span class="badge-available">
                                    <i class="bi bi-check-circle me-1"></i>12 Plazas
                                </span>
                            </div>
                            <h4>Clases de CrossFit</h4>

                            <div class="class-info">
                                <i class="bi bi-person-badge"></i>
                                <span>Instructor: <strong>Roberto Sánchez</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-clock"></i>
                                <span>Hora: <strong>6:00 AM - 7:00 AM</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-calendar-event"></i>
                                <span>Fecha: <strong>31/05/2026</strong></span>
                            </div>

                            <div class="class-info">
                                <i class="bi bi-geo-alt"></i>
                                <span>Sala: <strong>Box CrossFit</strong></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-center justify-content-center p-3">
                        <a href="#" class="btn btn-action">
                            <i class="bi bi-bookmark-plus"></i>
                            <span>Reservar</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Clase 5: HIIT -->
        <div class="col-12">
