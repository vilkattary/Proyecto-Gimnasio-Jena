@model GimnasioJena.Abstracciones.Modelos.Entrenadores.EntrenadorDto

@{
    ViewBag.Title = "Perfil del Entrenador";

    bool perfilPendiente =
        Model.especialidad == "Pendiente de completar" ||
        Model.descripcion == "Pendiente de completar";

    string[] nombres = Model.nombreCompleto != null ? Model.nombreCompleto.Split(' ') : new string[0];
    string iniciales = nombres.Length > 1
        ? nombres[0].Substring(0, 1) + nombres[1].Substring(0, 1)
        : (nombres.Length == 1 ? nombres[0].Substring(0, 1) : "E");
}

<div class="container-fluid p-4">

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    @if (perfilPendiente)
    {
        <div class="alert alert-warning">
            <strong>Perfil pendiente de completar.</strong>
            Tu información profesional todavía no ha sido actualizada por administración.
        </div>
    }

    <div class="text-center mb-5">
        <h2 class="page-title">Mi Perfil</h2>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <i class="bi bi-award"></i>
            <h3>@Model.especialidad</h3>
            <p>Especialidad</p>
        </div>

        <div class="stat-card">
            <i class="bi bi-calendar-event"></i>
            <h3>@Model.fechaContratacion.ToString("dd/MM/yyyy")</h3>
            <p>Contratado Desde</p>
        </div>

        <div class="stat-card">
            <i class="bi bi-star-fill"></i>
            <h3>@(Model.estado ? "Activo" : "Inactivo")</h3>
            <p>Estado</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="info-card">
                <div class="row">
                    <div class="col-md-4 profile-section mb-3 mb-md-0">
                        <div class="profile-avatar mx-auto">
                            @if (Model.Usuario != null && !string.IsNullOrWhiteSpace(Model.Usuario.fotoPerfil))
                            {
                                <img src="@Url.Content(Model.Usuario.fotoPerfil)"
                                     alt="Foto del entrenador"
                                     class="rounded-circle"
                                     style="width:120px;height:120px;object-fit:cover;border:3px solid var(--jena-orange);" />
                            }
                            else
                            {
                                <span class="initials">@iniciales</span>
                            }

                            @if (Model.estado)
                            {
                                <div class="verified-badge">
                                    <i class="bi bi-check-lg"></i>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="info-item">
                            <i class="bi bi-person-circle"></i>
                            <div class="info-content">
                                <div class="info-label">Nombre Completo</div>
                                <div class="info-value">@Model.nombreCompleto</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-envelope"></i>
                            <div class="info-content">
                                <div class="info-label">Correo Electrónico</div>
                                <div class="info-value">@Model.correo</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-award"></i>
                            <div class="info-content">
                                <div class="info-label">Especialidad</div>
                                <div class="info-value">@Model.especialidad</div>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="bi bi-calendar-event"></i>
                            <div class="info-content">
                                <div class="info-label">Fecha de Contratación</div>
                                <div class="info-value">@Model.fechaContratacion.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="description-card">
                <h5><i class="bi bi-info-circle me-2"></i>Descripción</h5>
                <p>
                    @Model.descripcion
                </p>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="action-buttons-card">
                <h5><i class="bi bi-lightning-charge me-2"></i>Acciones Rápidas</h5>

                <a href="@Url.Action("MisClases", "Entrenadores")" class="btn btn-action">
                    <i class="bi bi-lightning-charge-fill "></i>
                    <span>Mis Clases</span>
                </a>
                <a href="@Url.Action("EditarPerfil", "Manage")" class="btn btn-action">
                    <i class="bi bi-pencil-square"></i>
                    <span>Editar Perfil</span>
                </a>

                <a href="@Url.Action("ChangePassword", "Manage")" class="btn btn-action">
                    <i class="bi bi-shield-lock"></i>
                    <span>Cambiar Contraseña</span>
                </a>

                <a href="@Url.Action("Index", "Home")" class="btn btn-action">
                    <i class="bi bi-house-door"></i>
                    <span>Volver al Inicio</span>
                </a>
            </div>

            <div class="info-card">
                <h5 class="text-center mb-3" style="color: var(--jena-navy); font-weight: 800;">
                    <i class="bi bi-star-fill" style="color: var(--jena-orange);"></i>
                    Estado de Cuenta
                </h5>

                <div class="text-center">
                    <div class="mb-3">
                        <span style="font-size: 2rem; font-weight: 800; color: var(--jena-orange);">
                            @(Model.estado ? "Activo" : "Inactivo")
                        </span>
                    </div>

                    <div class="info-item" style="border: none; padding: 0; display: flex; align-items: center; justify-content: center; gap: 10px;">
                        <i class="bi bi-award"></i>
                        <div class="info-content" style="text-align: left;">
                            <div class="info-label">Especialidad</div>
                            <div class="info-value">@Model.especialidad</div>
                        </div>
                    </div>

                    <div class="info-item" style="border: none; padding: 0; display: flex; align-items: center; justify-content: center; gap: 10px;">
                        <i class="bi bi-calendar-check"></i>
                        <div class="info-content" style="text-align: left;">
                            <div class="info-label">Fecha de Contratación</div>
                            <div class="info-value">@Model.fechaContratacion.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                </div>
                </div>
            </div>
        </div>
    </div>
</div>
