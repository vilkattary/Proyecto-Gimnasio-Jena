@model IEnumerable<GimnasioJena.Abstracciones.Modelos.Entrenadores.EntrenadorListadoDto>

@{
    ViewBag.Title = "Administrar entrenadores";
}

<link href="@(Url.Content("~/Content/estilo/estilo.css"))" rel="stylesheet" />

<section class="container py-5">
    <h2 class="fw-bold mb-4" style="color:var(--gym-dark);">
        Administrar entrenadores
    </h2>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensajeError"]
        </div>
    }

    <div class="card shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Especialidad</th>
                            <th>Fecha contratación</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.nombreCompleto</td>
                                    <td>@item.correo</td>
                                    <td>@item.especialidad</td>
                                    <td>@item.fechaContratacion.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.estado)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactivo</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a href="@Url.Action("Editar", "Entrenadores", new { id = item.idEntrenador })"
                                           class="btn btn-sm btn-action">
                                            Editar
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">
                                    No hay entrenadores registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>