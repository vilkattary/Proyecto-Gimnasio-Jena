@model GimnasioJena.UI.Models.RegisterViewModel
@{
    ViewBag.Title = "Registro";
}
<link href="@(Url.Content("~/Content/estilo/estilo.css"))" rel="stylesheet" />
<section class="register-wrapper">
    <div class="register-card">
        <div class="card-body">
            <span class="register-brand">
                <i class="bi bi-lightning-charge-fill me-1"></i> GIMNASIO JENA
            </span>
            <h3 class="register-title">Crea tu cuenta</h3>
            @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-2" })

                <div class="mb-3">
                    <label class="form-label small">Nombre</label>
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Tu nombre" })
                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label small">Primer apellido</label>
                    @Html.TextBoxFor(m => m.Apellido1, new { @class = "form-control", placeholder = "Primer apellido" })
                    @Html.ValidationMessageFor(m => m.Apellido1, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label small">Segundo apellido</label>
                    @Html.TextBoxFor(m => m.Apellido2, new { @class = "form-control", placeholder = "Segundo apellido" })
                </div>

                <div class="mb-3">
                    <label class="form-label small">Identificación</label>
                    @Html.TextBoxFor(m => m.Identificacion, new { @class = "form-control", placeholder = "Número de identificación" })
                    @Html.ValidationMessageFor(m => m.Identificacion, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label small">Correo electrónico</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "tu@correo.com" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label small">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "********" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label small">Confirmar contraseña</label>
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "********" })
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label small">Teléfono (opcional)</label>
                    @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", placeholder = "+506 8xxxxxxx" })
                    <div class="form-text text-muted">Usaremos este número solo para notificaciones importantes.</div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-register">Crear cuenta</button>
                </div>

                <div class="text-center mt-3">
                    <span class="small text-muted">¿Ya tienes cuenta?</span>
                    <a href="@Url.Action("Login","Account")" class="ms-2">Inicia sesión</a>
                </div>
            }
        </div>
    </div>
</section>