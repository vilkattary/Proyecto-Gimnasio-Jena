@{
    ViewBag.Title = "Contraseña restablecida";
}

<link href="@(Url.Content("~/Content/estilo/estilo.css"))" rel="stylesheet" />

<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-sm-10 col-md-8 col-lg-5">
            <div class="card shadow-sm rounded-4 text-center" style="border-top:4px solid var(--gym-orange);">
                <div class="card-body p-4">

                    <div class="mb-3">
                        <i class="bi bi-check-circle-fill fs-1" style="color:var(--gym-orange);"></i>
                    </div>

                    <span class="d-inline-block fs-3 fst-italic" style="color:var(--gym-orange); font-family:'Oswald',sans-serif;">
                        <i class="bi bi-lightning-charge-fill me-1"></i>GIMNASIO JENA
                    </span>

                    <h2 class="h5 mt-3 fw-bold" style="color:var(--gym-dark);">
                        Contraseña restablecida
                    </h2>

                    <p class="text-muted mt-3">
                        Tu contraseña se restableció correctamente.
                    </p>

                    <a href="@Url.Action("Login", "Account")"
                       class="btn btn-action mt-3">
                        Iniciar sesión
                    </a>

                </div>
            </div>
        </div>
    </div>
</section>