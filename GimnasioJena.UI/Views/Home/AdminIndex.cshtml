@model IEnumerable<GimnasioJena.Abstracciones.Modelos.Home.ContenidoWebDto>
@using System.Linq
@{
    ViewBag.Title = "Administrar Inicio";
    var mensajeExito = TempData["MensajeExito"] as string;
    var mensajeError = TempData["MensajeError"] as string;

    var seccionHero = Model.Where(x => x.Seccion == "Hero").OrderBy(x => x.Orden).ToList();
    var seccionClases = Model.Where(x => x.Seccion == "Clases").OrderBy(x => x.Orden).Take(3).ToList();
    var seccionTestimonios = Model.Where(x => x.Seccion == "Testimonios").OrderBy(x => x.Orden).Take(3).ToList();
}

@if (!string.IsNullOrEmpty(mensajeExito))
{
    <div class="alert alert-success alert-dismissible fade show mb-0 mt-5 rounded-0 border-0 border-bottom"
         role="alert"
         style="border-bottom-color: var(--jena-orange) !important; background-color: #e8f5e9;">
        <div class="container d-flex align-items-center gap-2">
            <i class="bi bi-check-circle-fill fs-5" style="color: #2e7d32;"></i>
            <span class="fw-semibold" style="color: #1b5e20;">@mensajeExito</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="alert alert-danger alert-dismissible fade show mb-0 mt-5 rounded-0 border-0 border-bottom"
         role="alert"
         style="border-bottom-color: #c62828 !important; background-color: #ffebee;">
        <div class="container d-flex align-items-center gap-2">
            <i class="bi bi-exclamation-triangle-fill fs-5" style="color: #c62828;"></i>
            <span class="fw-semibold" style="color: #b71c1c;">@mensajeError</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    </div>
}

<div class="container py-5">

    <div class="row mb-5">
        <div class="col-12">
            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
                <div>
                    <h1 class="mb-1 text-uppercase" style="color: var(--jena-navy); font-size: clamp(1.5rem, 3vw, 2.2rem);">
                        <i class="bi bi-sliders me-2" style="color: var(--jena-orange);"></i>Administrar Inicio
                    </h1>
                    <p class="text-muted mb-0" style="font-family: var(--font-primary); font-size: 0.95rem;">
                        Gestione el contenido de la página pública. Las tarjetas son fijas y solo se pueden editar.
                    </p>
                </div>
                <a href="@Url.Action("Index", "Home")" target="_blank"
                   class="btn-action text-decoration-none"
                   style="width: auto; padding: 10px 24px; white-space: nowrap;">
                    <i class="bi bi-box-arrow-up-right"></i>Ver página pública
                </a>
            </div>
            <hr style="border-color: var(--jena-orange); border-width: 2px; opacity: 1; margin-top: 1.25rem;" />
        </div>
    </div>

    <div class="action-buttons-card mb-4">
        <h5>
            <i class="bi bi-image-fill me-2" style="color: var(--jena-orange);"></i>Sección Hero
        </h5>

        @if (!seccionHero.Any())
        {
            <div class="alert alert-warning" role="alert">
                <i class="bi bi-info-circle me-2"></i>No se encontraron registros para la sección <strong>Hero</strong>.
            </div>
        }
        else
        {
            foreach (var item in seccionHero)
            {
                <form action="@Url.Action("GuardarSeccion", "SeccionesHome")"
                      method="post"
                      enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@item.Id" />
                    <input type="hidden" name="Clave" value="@item.Clave" />
                    <input type="hidden" name="UrlImagen" value="@item.UrlImagen" />

                    <div class="row g-4 align-items-start">
                        @if (!string.IsNullOrEmpty(item.UrlImagen))
                        {
                            <div class="col-12 col-md-auto">
                                <label class="form-label fw-semibold d-block"
                                       style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                                    Imagen actual
                                </label>
                                <div style="position: relative; display: inline-block;">
                                    <img src="@item.UrlImagen"
                                         alt="Fondo Hero actual"
                                         class="img-thumbnail"
                                         style="width: 200px; height: 120px; object-fit: cover; border-radius: 10px; border: 2px solid var(--jena-light-blue);" />
                                    <span class="badge position-absolute top-0 start-0 m-1"
                                          style="background: var(--jena-navy); font-size: 0.7rem;">FONDO</span>
                                </div>
                            </div>
                        }

                        <div class="col-12 col-md">
                            <div class="mb-3">
                                <label class="form-label fw-semibold"
                                       style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                                    Título principal <span style="color: var(--jena-orange);">*</span>
                                </label>
                                <input type="text"
                                       name="TextoPrincipal"
                                       value="@item.TextoPrincipal"
                                       class="form-control"
                                       required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold"
                                       style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                                    Descripción / Subtítulo
                                </label>
                                <textarea name="TextoSecundario"
                                          class="form-control"
                                          rows="3">@item.TextoSecundario</textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold"
                                       style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                                    <i class="bi bi-upload me-1" style="color: var(--jena-orange);"></i>Reemplazar imagen de fondo
                                </label>
                                <input type="file"
                                       name="ArchivoImagen"
                                       accept="image/*"
                                       class="form-control" />
                                <div class="form-text">
                                    Formatos admitidos: JPG, PNG, WEBP. Recomendado: 1920×1080 px.
                                </div>
                            </div>

                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 pt-1">
                                <small class="text-muted" style="font-family: var(--font-primary); font-size: 0.78rem;">
                                    <i class="bi bi-clock me-1"></i>
                                    Última modificación: @(item.FechaModificacion.HasValue ? item.FechaModificacion.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                                </small>
                                <button type="submit" class="btn-action" style="width: auto; padding: 10px 28px;">
                                    <i class="bi bi-save-fill"></i>Guardar Hero
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            }
        }
    </div>

    <div class="action-buttons-card mb-4">
        <h5>
            <i class="bi bi-collection-fill me-2" style="color: var(--jena-orange);"></i>Nuestras Clases
        </h5>

        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Esta sección utiliza 3 tarjetas fijas. Para cambiar una clase visible, edite su nombre, descripción e ícono.
        </div>

        @if (seccionClases.Any())
        {
            <div class="row g-4 mb-3 justify-content-center">
                @foreach (var item in seccionClases)
                {
                    bool esIconoBI = !string.IsNullOrEmpty(item.UrlImagen) && item.UrlImagen.StartsWith("bi-");
                    string iconoActual = esIconoBI ? item.UrlImagen : "bi-star-fill";

                    <div class="col-12 col-lg-4">
                        <div class="h-100"
                             style="border: 1px solid var(--jena-light-blue); border-radius: 15px; overflow: hidden; background: var(--jena-white); box-shadow: 0 4px 15px rgba(0,0,0,0.06);">

                            <div class="d-flex align-items-center justify-content-between px-3 py-2"
                                 style="background: var(--jena-navy);">
                                <span class="text-uppercase fw-bold"
                                      style="color: var(--jena-white); font-family: var(--font-primary); font-size: 0.78rem; letter-spacing: 1.5px;">
                                    Tarjeta de clase
                                </span>

                                <span class="rounded-circle d-flex align-items-center justify-content-center"
                                      style="width:36px; height:36px; background: var(--jena-orange);">
                                    <i class="bi @iconoActual text-white" style="font-size: 1.1rem;"></i>
                                </span>
                            </div>

                            <div class="p-3">
                                <form action="@Url.Action("GuardarSeccion", "SeccionesHome")"
                                      method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@item.Id" />
                                    <input type="hidden" name="Clave" value="@item.Clave" />

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"
                                               style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1px;">
                                            Nombre de la clase <span style="color: var(--jena-orange);">*</span>
                                        </label>
                                        <input type="text"
                                               name="TextoPrincipal"
                                               value="@item.TextoPrincipal"
                                               class="form-control"
                                               required />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"
                                               style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1px;">
                                            Descripción
                                        </label>
                                        <textarea name="TextoSecundario"
                                                  class="form-control"
                                                  rows="3">@item.TextoSecundario</textarea>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"
                                               style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1px;">
                                            <i class="bi bi-palette-fill me-1" style="color: var(--jena-orange);"></i>Ícono
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text px-3"
                                                  style="background: var(--jena-navy); border-color: var(--jena-navy); min-width:52px; font-size:1.4rem;">
                                                <i class="bi @iconoActual text-white" id="icono-i-@item.Id"></i>
                                            </span>
                                            <select name="UrlImagen" class="form-select"
                                                    onchange="actualizarIconoBI('@item.Id', this.value)">
                                                <option value="bi-lightning-charge-fill" @Html.Raw(item.UrlImagen == "bi-lightning-charge-fill" ? " selected" : "")> Fuerza / Potencia</option>
                                                <option value="bi-heart-pulse-fill" @Html.Raw(item.UrlImagen == "bi-heart-pulse-fill" ? " selected" : "")> Cardio / Salud</option>
                                                <option value="bi-fire" @Html.Raw(item.UrlImagen == "bi-fire" ? " selected" : "")> Quema calorías</option>
                                                <option value="bi-bicycle" @Html.Raw(item.UrlImagen == "bi-bicycle" ? " selected" : "")> Ciclismo / Spinning</option>
                                                <option value="bi-person-arms-up" @Html.Raw(item.UrlImagen == "bi-person-arms-up" ? " selected" : "")> Ejercicio general</option>
                                                <option value="bi-trophy-fill" @Html.Raw(item.UrlImagen == "bi-trophy-fill" ? " selected" : "")> Competencia / Reto</option>
                                                <option value="bi-stopwatch-fill" @Html.Raw(item.UrlImagen == "bi-stopwatch-fill" ? " selected" : "")> Velocidad / Tiempo</option>
                                                <option value="bi-activity" @Html.Raw(item.UrlImagen == "bi-activity" ? " selected" : "")> Actividad física</option>
                                                <option value="bi-peace-fill" @Html.Raw(item.UrlImagen == "bi-peace-fill" ? " selected" : "")> Yoga / Mindfulness</option>
                                                <option value="bi-music-note-beamed" @Html.Raw(item.UrlImagen == "bi-music-note-beamed" ? " selected" : "")> Danza / Zumba</option>
                                                <option value="bi-shield-fill-check" @Html.Raw(item.UrlImagen == "bi-shield-fill-check" ? " selected" : "")> Defensa / Artes marciales</option>
                                                <option value="bi-water" @Html.Raw(item.UrlImagen == "bi-water" ? " selected" : "")> Natación / Aqua</option>
                                                <option value="bi-wind" @Html.Raw(item.UrlImagen == "bi-wind" ? " selected" : "")> Respiración / Flexibilidad</option>
                                                <option value="bi-arrow-up-circle-fill" @Html.Raw(item.UrlImagen == "bi-arrow-up-circle-fill" ? " selected" : "")> Progreso / Superación</option>
                                                <option value="bi-stars" @Html.Raw(item.UrlImagen == "bi-stars" ? " selected" : "")> Élite / Premium</option>
                                                <option value="bi-star-fill" @Html.Raw(item.UrlImagen == "bi-star-fill" ? " selected" : "")> General</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-1 pt-1">
                                        <small class="text-muted" style="font-size: 0.75rem;">
                                            <i class="bi bi-clock me-1"></i>@(item.FechaModificacion.HasValue ? item.FechaModificacion.Value.ToString("dd/MM/yy HH:mm") : "-")
                                        </small>
                                        <button type="submit" class="btn-action" style="width: auto; padding: 8px 20px; font-size: 0.85rem; margin-bottom: 0;">
                                            <i class="bi bi-save-fill"></i>Guardar
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="action-buttons-card mb-4">
        <h5>
            <i class="bi bi-chat-quote-fill me-2" style="color: var(--jena-orange);"></i>Testimonios de Clientes
        </h5>

        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Esta sección utiliza 3 testimonios fijos. Para cambiar uno visible, edite el nombre, testimonio o avatar.
        </div>

        @if (seccionTestimonios.Any())
        {
            <div class="row g-4 mb-3 justify-content-center">
                @foreach (var item in seccionTestimonios)
                {
                    string iniciales = "?";

                    if (item.TextoPrincipal != null && item.TextoPrincipal.Length >= 1)
                    {
                        iniciales = item.TextoPrincipal.Substring(0, 1).ToUpper();
                        int ultimoEspacio = item.TextoPrincipal.LastIndexOf(' ');

                        if (ultimoEspacio > 0)
                        {
                            iniciales += item.TextoPrincipal.Substring(ultimoEspacio + 1, 1).ToUpper();
                        }
                    }

                    <div class="col-12 col-lg-4">
                        <div class="h-100"
                             style="border: 1px solid var(--jena-light-blue); border-radius: 15px; overflow: hidden; background: var(--jena-white); box-shadow: 0 4px 15px rgba(0,0,0,0.06);">

                            <div class="d-flex align-items-center justify-content-between px-3 py-2"
                                 style="background: #293039;">
                                <span class="fw-bold"
                                      style="color: #FF6600; font-family: var(--font-primary); font-size: 0.78rem; letter-spacing: 1px;">
                                    <i class="bi bi-quote me-1"></i>Tarjeta de testimonio
                                </span>

                                @if (!string.IsNullOrEmpty(item.UrlImagen))
                                {
                                    <img src="@item.UrlImagen"
                                         alt="Avatar @item.TextoPrincipal"
                                         style="width: 36px; height: 36px; object-fit: cover; border-radius: 50%; border: 2px solid #FF6600;" />
                                }
                                else
                                {
                                    <span class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                          style="width:36px; height:36px; background: #FF6600; color: #fff; font-size: 0.85rem;">
                                        @iniciales
                                    </span>
                                }
                            </div>

                            <div class="p-3">
                                <form action="@Url.Action("GuardarSeccion", "SeccionesHome")"
                                      method="post"
                                      enctype="multipart/form-data">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@item.Id" />
                                    <input type="hidden" name="Clave" value="@item.Clave" />

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"
                                               style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1px;">
                                            Nombre del cliente <span style="color: var(--jena-orange);">*</span>
                                        </label>
                                        <input type="text"
                                               name="TextoPrincipal"
                                               value="@item.TextoPrincipal"
                                               class="form-control"
                                               required />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"
                                               style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1px;">
                                            Testimonio / Cita
                                        </label>
                                        <textarea name="TextoSecundario"
                                                  class="form-control"
                                                  rows="4">@item.TextoSecundario</textarea>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"
                                               style="color: var(--jena-navy); font-family: var(--font-primary); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1px;">
                                            <i class="bi bi-upload me-1" style="color: var(--jena-orange);"></i>Avatar
                                        </label>
                                        <input type="file"
                                               name="ArchivoImagen"
                                               accept="image/*"
                                               class="form-control" />
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-1 pt-1">
                                        <small class="text-muted" style="font-size: 0.75rem;">
                                            <i class="bi bi-clock me-1"></i>@(item.FechaModificacion.HasValue ? item.FechaModificacion.Value.ToString("dd/MM/yy HH:mm") : "-")
                                        </small>
                                        <button type="submit" class="btn-action" style="width: auto; padding: 8px 20px; font-size: 0.85rem; margin-bottom: 0;">
                                            <i class="bi bi-save-fill"></i>Guardar
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

@section scripts {
    <script>
        function actualizarIconoBI(itemId, iconClass) {
            var el = document.getElementById('icono-i-' + itemId);
            if (el) {
                el.className = 'bi ' + iconClass + ' text-white';
            }
        }
    </script>
}