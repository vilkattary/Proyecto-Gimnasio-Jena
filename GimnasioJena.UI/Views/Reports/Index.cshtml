
@{
    ViewBag.Title = "Index";
}

<style>

    .rpt-root {
        padding: 1.5rem 1.5rem 2rem;
        min-height: 100vh
    }

    .rpt-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 2rem;
        gap: 1rem;
        flex-wrap: wrap
    }

    .rpt-title-block {
    }

    .rpt-eyebrow {
        font-size: 11px;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        margin-bottom: 4px
    }

    .rpt-title {
        font-family: 'Barlow Condensed',sans-serif;
        font-size: 32px;
        font-weight: 700;
        color: var(--color-text-primary);
        line-height: 1
    }

    .rpt-date {
        font-size: 13px;
        color: var(--color-text-secondary);
        margin-top: 6px
    }

    .rpt-nav {
        display: flex;
        gap: 8px;
        flex-wrap: wrap
    }

    .nav-pill {
        font-size: 12px;
        padding: 6px 14px;
        border-radius: 99px;
        border: 0.5px solid var(--color-border-secondary);
        cursor: pointer;
        color: var(--color-text-secondary);
        background: transparent;
        font-family: 'DM Sans',sans-serif;
        transition: all .15s
    }

        .nav-pill.active, .nav-pill:hover {
            background: var(--color-background-secondary);
            color: var(--color-text-primary);
            border-color: var(--color-border-primary)
        }

    .section {
        display: none
    }

        .section.visible {
            display: block
        }

    .metric-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(130px,1fr));
        gap: 10px;
        margin-bottom: 1.5rem
    }

    .metric-card {
        background: var(--color-background-secondary);
        border-radius: var(--border-radius-md);
        padding: 1rem
    }

    .metric-label {
        font-size: 12px;
        color: var(--color-text-tertiary);
        margin-bottom: 4px
    }

    .metric-value {
        font-family: 'Barlow Condensed',sans-serif;
        font-size: 28px;
        font-weight: 600;
        color: var(--color-text-primary);
        line-height: 1
    }

    .metric-sub {
        font-size: 11px;
        margin-top: 3px
    }

    .up {
        color: #3B6D11
    }

    .down {
        color: #A32D2D
    }

    .neutral {
        color: var(--color-text-tertiary)
    }

    .chart-card {
        background: var(--color-background-primary);
        border: 0.5px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg);
        padding: 1.25rem;
        margin-bottom: 1.25rem
    }

    .chart-label {
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text-secondary);
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: .06em
    }

    .row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        margin-bottom: 1.25rem
    }

    .rank-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 0.5px solid var(--color-border-tertiary)
    }

        .rank-row:last-child {
            border-bottom: none
        }

    .rank-num {
        font-family: 'Barlow Condensed',sans-serif;
        font-size: 18px;
        font-weight: 600;
        width: 22px;
        text-align: right;
        color: var(--color-text-tertiary);
        flex-shrink: 0
    }

        .rank-num.gold {
            color: #BA7517
        }

    .rank-name {
        flex: 1;
        font-size: 14px;
        color: var(--color-text-primary)
    }

    .rank-bar-wrap {
        width: 100px;
        height: 6px;
        background: var(--color-background-secondary);
        border-radius: 3px;
        overflow: hidden;
        flex-shrink: 0
    }

    .rank-bar {
        height: 100%;
        border-radius: 3px;
        background: #185FA5
    }

    .rank-val {
        font-size: 13px;
        font-weight: 500;
        color: var(--color-text-secondary);
        width: 38px;
        text-align: right;
        flex-shrink: 0
    }

    .trainer-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 0;
        border-bottom: 0.5px solid var(--color-border-tertiary)
    }

        .trainer-row:last-child {
            border-bottom: none
        }

    .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 500;
        flex-shrink: 0
    }

        .avatar.a {
            background: #E6F1FB;
            color: #0C447C
        }

        .avatar.b {
            background: #EAF3DE;
            color: #3B6D11
        }

        .avatar.c {
            background: #FAEEDA;
            color: #854F0B
        }

        .avatar.d {
            background: #FBEAF0;
            color: #72243E
        }

        .avatar.e {
            background: #EEEDFE;
            color: #3C3489
        }

    .trainer-info {
        flex: 1;
        min-width: 0
    }

    .trainer-name {
        font-size: 14px;
        color: var(--color-text-primary)
    }

    .trainer-classes {
        font-size: 11px;
        color: var(--color-text-tertiary);
        margin-top: 1px
    }

    .badge {
        font-size: 11px;
        padding: 3px 9px;
        border-radius: 99px;
        white-space: nowrap;
        flex-shrink: 0
    }

    .badge-blue {
        background: #E6F1FB;
        color: #0C447C
    }

    .badge-green {
        background: #EAF3DE;
        color: #3B6D11
    }

    .badge-amber {
        background: #FAEEDA;
        color: #854F0B
    }

    .survey-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem
    }

    .survey-item {
        padding: 1rem;
        border-radius: var(--border-radius-md);
        border: 0.5px solid var(--color-border-tertiary)
    }

    .survey-q {
        font-size: 12px;
        color: var(--color-text-secondary);
        margin-bottom: .75rem
    }

    .survey-score {
        font-family: 'Barlow Condensed',sans-serif;
        font-size: 36px;
        font-weight: 600;
        color: var(--color-text-primary);
        line-height: 1;
        margin-bottom: .5rem
    }

    .star-row {
        display: flex;
        gap: 2px;
        margin-bottom: .5rem
    }

    .star {
        width: 14px;
        height: 14px
    }

    .survey-bars {
        display: flex;
        flex-direction: column;
        gap: 5px
    }

    .sbar-row {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 11px;
        color: var(--color-text-tertiary)
    }

    .sbar-wrap {
        flex: 1;
        height: 5px;
        background: var(--color-background-secondary);
        border-radius: 3px;
        overflow: hidden
    }

    .sbar {
        height: 100%;
        border-radius: 3px
    }

    .membership-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 10px
    }

    .leg-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--color-text-secondary)
    }

    .leg-sq {
        width: 10px;
        height: 10px;
        border-radius: 2px;
        flex-shrink: 0
    }

    .member-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px
    }

        .member-table th {
            text-align: left;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: var(--color-text-tertiary);
            font-weight: 500;
            padding: 4px 8px 8px 0;
            border-bottom: 0.5px solid var(--color-border-tertiary)
        }

        .member-table td {
            padding: 9px 8px 9px 0;
            border-bottom: 0.5px solid var(--color-border-tertiary);
            color: var(--color-text-primary)
        }

        .member-table tr:last-child td {
            border-bottom: none
        }

    .status-pill {
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 99px
    }

    .sp-activo {
        background: #EAF3DE;
        color: #3B6D11
    }

    .sp-nuevo {
        background: #E6F1FB;
        color: #0C447C
    }

    .sp-inactivo {
        background: #F1EFE8;
        color: #5F5E5A
    }

</style>


<div class="rpt-root">
    
    <div class="rpt-header">
        <div class="rpt-title-block">
            <div class="rpt-title">Panel General</div>
        </div>
        <div class="rpt-nav">
            <button class="nav-pill active" onclick="showSection('clientes',this)">Clientes</button>
            <button class="nav-pill" onclick="showSection('clases',this)">Clases</button>
            <button class="nav-pill" onclick="showSection('entrenadores',this)">Entrenadores</button>
            <button class="nav-pill" onclick="showSection('encuestas',this)">Encuestas</button>
        </div>
    </div>

    <!-- CLIENTES -->
    <div id="sec-clientes" class="section visible">
        <div class="metric-grid">
            <div class="metric-card"><div class="metric-label">Miembros activos</div><div class="metric-value">348</div><div class="metric-sub up">↑ 12% vs mes anterior</div></div>
            <div class="metric-card"><div class="metric-label">Nuevos este mes</div><div class="metric-value">41</div><div class="metric-sub up">↑ 8 vs marzo</div></div>
            <div class="metric-card"><div class="metric-label">Bajas este mes</div><div class="metric-value">14</div><div class="metric-sub down">↑ 2 vs marzo</div></div>
            <div class="metric-card"><div class="metric-label">Tasa retención</div><div class="metric-value">96%</div><div class="metric-sub neutral">Estable</div></div>
        </div>
        <div class="chart-card">
            <div class="chart-label">Ingresos nuevos por mes — 2025</div>
            <div style="position:relative;width:100%;height:220px"><canvas id="chartNuevos" role="img" aria-label="Barras de nuevos miembros por mes 2025">Ene:28 Feb:32 Mar:33 Abr:41</canvas></div>
        </div>
        <div class="row2">
            <div class="chart-card">
                <div class="chart-label">Distribución de membresías</div>
                <div class="membership-legend">
                    <span class="leg-item"><span class="leg-sq" style="background:#185FA5"></span>Mensual (52%)</span>
                    <span class="leg-item"><span class="leg-sq" style="background:#1D9E75"></span>Trimestral (28%)</span>
                    <span class="leg-item"><span class="leg-sq" style="background:#BA7517"></span>Anual (20%)</span>
                </div>
                <div style="position:relative;width:100%;height:160px"><canvas id="chartMemb" role="img" aria-label="Distribución de tipos de membresía">Mensual 52%, Trimestral 28%, Anual 20%</canvas></div>
            </div>
            <div class="chart-card">
                <div class="chart-label">Últimos ingresos</div>
                <table class="member-table">
                    <thead><tr><th>Nombre</th><th>Plan</th><th>Estado</th></tr></thead>
                    <tbody>
                        <tr><td>Laura Mora</td><td>Anual</td><td><span class="status-pill sp-nuevo">Nuevo</span></td></tr>
                        <tr><td>Diego Vargas</td><td>Mensual</td><td><span class="status-pill sp-activo">Activo</span></td></tr>
                        <tr><td>Ana Jiménez</td><td>Trimestral</td><td><span class="status-pill sp-nuevo">Nuevo</span></td></tr>
                        <tr><td>Carlos Brenes</td><td>Mensual</td><td><span class="status-pill sp-activo">Activo</span></td></tr>
                        <tr><td>Sofía Núñez</td><td>Anual</td><td><span class="status-pill sp-nuevo">Nuevo</span></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- CLASES -->
    <div id="sec-clases" class="section">
        <div class="metric-grid">
            <div class="metric-card"><div class="metric-label">Clases impartidas</div><div class="metric-value">124</div><div class="metric-sub neutral">Este mes</div></div>
            <div class="metric-card"><div class="metric-label">Asistentes totales</div><div class="metric-value">2,190</div><div class="metric-sub up">↑ 7% vs marzo</div></div>
            <div class="metric-card"><div class="metric-label">Ocupación promedio</div><div class="metric-value">78%</div><div class="metric-sub up">↑ 4pp</div></div>
            <div class="metric-card"><div class="metric-label">Clase más llena</div><div class="metric-value">HIIT</div><div class="metric-sub neutral">95% ocupación</div></div>
        </div>
        <div class="chart-card">
            <div class="chart-label">Ranking — clases más populares (asistentes/mes)</div>
            <div id="rankingClases"></div>
        </div>
        <div class="chart-card" style="margin-bottom:0">
            <div class="chart-label">Asistencia por categoría</div>
            <div style="position:relative;width:100%;height:200px"><canvas id="chartCats" role="img" aria-label="Asistencia mensual por categoría de clase">Funcional:520 Yoga:410 Spinning:390 Pilates:320 Boxeo:280 Zumba:270</canvas></div>
        </div>
    </div>

    <!-- ENTRENADORES -->
    <div id="sec-entrenadores" class="section">
        <div class="metric-grid">
            <div class="metric-card"><div class="metric-label">Entrenadores activos</div><div class="metric-value">8</div><div class="metric-sub neutral">Planilla completa</div></div>
            <div class="metric-card"><div class="metric-label">Clases promedio</div><div class="metric-value">15.5</div><div class="metric-sub neutral">por entrenador/mes</div></div>
            <div class="metric-card"><div class="metric-label">Mejor valorado</div><div class="metric-value">Marcos R.</div><div class="metric-sub up">★ 4.9</div></div>
            <div class="metric-card"><div class="metric-label">Mayor carga</div><div class="metric-value">Valeria G.</div><div class="metric-sub neutral">24 clases</div></div>
        </div>
        <div class="row2">
            <div class="chart-card">
                <div class="chart-label">Clases por entrenador (mes actual)</div>
                <div id="trainerClases"></div>
            </div>
            <div class="chart-card">
                <div class="chart-label">Detalle de entrenadores</div>
                <div id="trainerList"></div>
            </div>
        </div>
        <div class="chart-card" style="margin-bottom:0">
            <div class="chart-label">Distribución de clases por entrenador</div>
            <div style="position:relative;width:100%;height:220px"><canvas id="chartTrainers" role="img" aria-label="Clases impartidas por cada entrenador este mes">Valeria:24 Marcos:22 Sofía:18 Andrés:16 Daniela:14 Luis:12 Carmen:10 Roberto:8</canvas></div>
        </div>
    </div>

    <!-- ENCUESTAS -->
    <div id="sec-encuestas" class="section">
        <div class="metric-grid">
            <div class="metric-card"><div class="metric-label">Respuestas recibidas</div><div class="metric-value">213</div><div class="metric-sub neutral">Último mes</div></div>
            <div class="metric-card"><div class="metric-label">Satisfacción global</div><div class="metric-value">4.6</div><div class="metric-sub up">↑ 0.2 vs mes ant.</div></div>
            <div class="metric-card"><div class="metric-label">NPS del gym</div><div class="metric-value">72</div><div class="metric-sub up">Excelente</div></div>
            <div class="metric-card"><div class="metric-label">Recomendarían</div><div class="metric-value">91%</div><div class="metric-sub neutral">de encuestados</div></div>
        </div>
        <div class="survey-grid" id="surveyGrid"></div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script src="~/Content/script/script.js"></script>

